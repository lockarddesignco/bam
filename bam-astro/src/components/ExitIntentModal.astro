---
const classifications = [
  'Healthcare',
  'Senior care',
  'Education',
  'Industrial',
  'Government',
  'Commercial',
  'Retail',
  'Cold storage',
  'Other',
];
---

<div
  id="exit-intent-overlay"
  class="fixed inset-0 z-[999] hidden items-center justify-center bg-dark/60 backdrop-blur-sm"
  aria-hidden="true"
>
  <div
    id="exit-intent-dialog"
    class="relative mx-4 w-full max-w-5xl rounded-xl bg-white p-6 shadow-2xl sm:p-10"
    role="dialog"
    aria-modal="true"
    aria-labelledby="exit-intent-heading"
  >
    <!-- Close button -->
    <button
      id="exit-intent-close"
      type="button"
      class="absolute right-4 top-4 flex h-9 w-9 items-center justify-center rounded-full text-slate transition-colors hover:bg-light-grey/40"
      aria-label="Close"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>

    <!-- Header -->
    <div class="mb-6 sm:mb-8">
      <span class="mb-4 inline-block rounded-full border border-mint/30 bg-mint/10 px-4 py-1.5 text-[10px] font-bold uppercase tracking-[0.22em] text-primary">
        Facility Assessment Intake
      </span>
      <h2 id="exit-intent-heading" class="mb-3 text-2xl font-black leading-tight tracking-tight text-primary sm:text-4xl">
        Request an Institutional Assessment
      </h2>
      <p class="max-w-3xl text-sm leading-relaxed text-slate sm:text-[15px]">
        Same-day intake for mission-critical facilities. Complete this quick form and our commercial team will respond within one business day.
      </p>
    </div>

    <!-- Form -->
    <form
      name="exit-intent-intake"
      method="POST"
      action="/thank-you/"
      data-netlify="true"
      netlify-honeypot="bot-field"
      class="space-y-6"
    >
      <input type="hidden" name="form-name" value="exit-intent-intake" />
      <p class="hidden"><label>Don't fill this out: <input name="bot-field" /></label></p>

      <div class="grid grid-cols-1 gap-5 md:grid-cols-2">
        <div class="space-y-1.5">
          <label for="ei-name" class="text-[10px] font-semibold uppercase tracking-widest text-slate">Full Name *</label>
          <input
            id="ei-name"
            name="name"
            type="text"
            required
            placeholder="John Smith"
            class="w-full rounded border border-light-grey bg-ice px-4 py-3 text-sm text-dark placeholder:text-slate/60 focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary/20"
          />
        </div>

        <div class="space-y-1.5">
          <label for="ei-title" class="text-[10px] font-semibold uppercase tracking-widest text-slate">Title / Role *</label>
          <input
            id="ei-title"
            name="job_title"
            type="text"
            required
            placeholder="Director of Facilities"
            class="w-full rounded border border-light-grey bg-ice px-4 py-3 text-sm text-dark placeholder:text-slate/60 focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary/20"
          />
        </div>

        <div class="space-y-1.5">
          <label for="ei-facility" class="text-[10px] font-semibold uppercase tracking-widest text-slate">Organization / Facility *</label>
          <input
            id="ei-facility"
            name="companyName"
            type="text"
            required
            placeholder="Memorial Regional Hospital"
            class="w-full rounded border border-light-grey bg-ice px-4 py-3 text-sm text-dark placeholder:text-slate/60 focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary/20"
          />
        </div>

        <div class="space-y-1.5">
          <label for="ei-classification" class="text-[10px] font-semibold uppercase tracking-widest text-slate">Facility Type *</label>
          <select
            id="ei-classification"
            name="facility_type"
            required
            class="w-full rounded border border-light-grey bg-ice px-4 py-3 text-sm text-dark focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary/20"
          >
            <option value="" disabled selected>Select facility type</option>
            {classifications.map((c) => (
              <option value={c}>{c}</option>
            ))}
          </select>
        </div>

        <div class="space-y-1.5">
          <label for="ei-email" class="text-[10px] font-semibold uppercase tracking-widest text-slate">Email Address *</label>
          <input
            id="ei-email"
            name="email"
            type="email"
            required
            placeholder="name@facility-domain.gov"
            class="w-full rounded border border-light-grey bg-ice px-4 py-3 text-sm text-dark placeholder:text-slate/60 focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary/20"
          />
        </div>

        <div class="space-y-1.5">
          <label for="ei-phone" class="text-[10px] font-semibold uppercase tracking-widest text-slate">Phone Number</label>
          <input
            id="ei-phone"
            name="phone"
            type="tel"
            placeholder="(555) 123-4567"
            class="w-full rounded border border-light-grey bg-ice px-4 py-3 text-sm text-dark placeholder:text-slate/60 focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary/20"
          />
        </div>
      </div>

      <div class="space-y-1.5">
        <label for="ei-deficiencies" class="text-[10px] font-semibold uppercase tracking-widest text-slate">Brief Description *</label>
        <textarea
          id="ei-deficiencies"
          name="describe_your_needs"
          rows="2"
          required
          placeholder="Current HVAC issues, compliance concerns, or scope needed."
          class="w-full resize-none rounded border border-light-grey bg-ice px-4 py-3 text-sm text-dark placeholder:text-slate/60 focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary/20"
        ></textarea>
      </div>

      <button
        type="submit"
        class="w-full rounded-sm bg-primary px-6 py-4 text-sm font-bold uppercase tracking-[0.2em] text-white transition-colors hover:bg-primary/90"
      >
        Submit Assessment Request
      </button>
    </form>

    <!-- Footer trust signals -->
    <div class="mt-5 flex flex-col gap-2 text-xs text-slate sm:flex-row sm:items-center sm:justify-between">
      <span class="inline-flex items-center gap-1.5">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
        </svg>
        Restricted data handling. Commercial intake only.
      </span>
      <span class="inline-flex items-center gap-1.5">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
        </svg>
        Submission processed through a secured data channel.
      </span>
    </div>
  </div>
</div>

<script>
  const STORAGE_KEY = 'bam_exit_intent_v3';

  function wasAlreadyShown(): boolean {
    try {
      return sessionStorage.getItem(STORAGE_KEY) === '1';
    } catch {
      return false;
    }
  }

  function markAsShown(): void {
    try {
      sessionStorage.setItem(STORAGE_KEY, '1');
    } catch { /* private browsing */ }
  }

  function showModal(): void {
    if (wasAlreadyShown()) return;
    markAsShown();
    cleanup();

    const overlay = document.getElementById('exit-intent-overlay');
    if (!overlay) return;

    overlay.classList.remove('hidden');
    overlay.classList.add('flex');
    overlay.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }

  function closeModal(): void {
    const overlay = document.getElementById('exit-intent-overlay');
    if (!overlay) return;

    overlay.classList.add('hidden');
    overlay.classList.remove('flex');
    overlay.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  let timer: ReturnType<typeof setTimeout> | null = null;

  function handleMouseLeave(e: MouseEvent): void {
    if (e.clientY <= 0) showModal();
  }

  function cleanup(): void {
    document.removeEventListener('mouseleave', handleMouseLeave);
    if (timer) {
      clearTimeout(timer);
      timer = null;
    }
  }

  function init(): void {
    if (wasAlreadyShown()) return;

    document.addEventListener('mouseleave', handleMouseLeave);
    timer = setTimeout(showModal, 30_000);

    document.getElementById('exit-intent-close')?.addEventListener('click', closeModal);

    document.getElementById('exit-intent-overlay')?.addEventListener('click', (e) => {
      if ((e.target as HTMLElement).id === 'exit-intent-overlay') closeModal();
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeModal();
    });
  }

  init();
</script>
