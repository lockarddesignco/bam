---
const classifications = [
  'Healthcare',
  'Senior care',
  'Education',
  'Industrial',
  'Government',
  'Commercial',
  'Retail',
  'Cold storage',
  'Other',
];
---

<div
  id="exit-intent-overlay"
  class="fixed inset-0 z-[999] hidden items-center justify-center bg-dark/60 backdrop-blur-sm"
  aria-hidden="true"
>
  <div
    id="exit-intent-dialog"
    class="relative mx-4 max-h-[90vh] w-full max-w-3xl overflow-y-auto rounded-xl bg-white p-6 shadow-2xl sm:p-10"
    role="dialog"
    aria-modal="true"
    aria-labelledby="exit-intent-heading"
  >
    <!-- Close button -->
    <button
      id="exit-intent-close"
      type="button"
      class="absolute right-4 top-4 flex h-9 w-9 items-center justify-center rounded-full text-slate transition-colors hover:bg-light-grey/40"
      aria-label="Close"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>

    <!-- Header -->
    <div class="mb-6 text-center sm:mb-8">
      <span class="mb-3 inline-block rounded-full bg-primary/10 px-4 py-1 text-xs font-semibold tracking-wide text-primary">
        Facility Assessment Intake
      </span>
      <h2 id="exit-intent-heading" class="mb-2 text-2xl leading-tight text-dark sm:text-3xl">
        Before You Go — <span class="font-bold">Request a Confidential Assessment</span>
      </h2>
      <p class="mx-auto max-w-lg text-sm leading-relaxed text-slate">
        Complete this form to receive a no-obligation preliminary evaluation of your facility's mechanical restoration needs.
      </p>
    </div>

    <!-- Form -->
    <form
      name="exit-intent-intake"
      method="POST"
      action="/thank-you/"
      data-netlify="true"
      class="space-y-4"
    >
      <input type="hidden" name="form-name" value="exit-intent-intake" />

      <div>
        <label for="ei-name" class="mb-1 block text-sm font-medium text-primary">Authorizing official name</label>
        <input
          id="ei-name"
          name="authorizing_official_name"
          type="text"
          required
          placeholder="Full legal name"
          class="w-full rounded-sm border border-light-grey/60 bg-white px-4 py-2.5 text-sm text-dark placeholder:text-slate/50 focus:border-primary focus:ring-2 focus:ring-primary/20 focus:outline-none"
        />
      </div>

      <div>
        <label for="ei-title" class="mb-1 block text-sm font-medium text-primary">Institutional title / role</label>
        <input
          id="ei-title"
          name="institutional_title"
          type="text"
          required
          placeholder="e.g. Director of Facilities"
          class="w-full rounded-sm border border-light-grey/60 bg-white px-4 py-2.5 text-sm text-dark placeholder:text-slate/50 focus:border-primary focus:ring-2 focus:ring-primary/20 focus:outline-none"
        />
      </div>

      <div>
        <label for="ei-facility" class="mb-1 block text-sm font-medium text-primary">Facility / organization name</label>
        <input
          id="ei-facility"
          name="facility_name"
          type="text"
          required
          placeholder="Legal entity name"
          class="w-full rounded-sm border border-light-grey/60 bg-white px-4 py-2.5 text-sm text-dark placeholder:text-slate/50 focus:border-primary focus:ring-2 focus:ring-primary/20 focus:outline-none"
        />
      </div>

      <div>
        <label for="ei-classification" class="mb-1 block text-sm font-medium text-primary">Facility classification</label>
        <select
          id="ei-classification"
          name="facility_classification"
          required
          class="w-full rounded-sm border border-light-grey/60 bg-white px-4 py-2.5 text-sm text-dark focus:border-primary focus:ring-2 focus:ring-primary/20 focus:outline-none"
        >
          <option value="" disabled selected>Select classification</option>
          {classifications.map((c) => (
            <option value={c}>{c}</option>
          ))}
        </select>
      </div>

      <div>
        <label for="ei-email" class="mb-1 block text-sm font-medium text-primary">Institutional email address</label>
        <input
          id="ei-email"
          name="institutional_email"
          type="email"
          required
          placeholder="name@facility-domain.gov"
          class="w-full rounded-sm border border-light-grey/60 bg-white px-4 py-2.5 text-sm text-dark placeholder:text-slate/50 focus:border-primary focus:ring-2 focus:ring-primary/20 focus:outline-none"
        />
      </div>

      <div>
        <label for="ei-address" class="mb-1 block text-sm font-medium text-primary">Primary service address</label>
        <input
          id="ei-address"
          name="service_address"
          type="text"
          required
          placeholder="Street, City, State"
          class="w-full rounded-sm border border-light-grey/60 bg-white px-4 py-2.5 text-sm text-dark placeholder:text-slate/50 focus:border-primary focus:ring-2 focus:ring-primary/20 focus:outline-none"
        />
      </div>

      <div>
        <label for="ei-deficiencies" class="mb-1 block text-sm font-medium text-primary">Summary of mechanical deficiencies</label>
        <textarea
          id="ei-deficiencies"
          name="mechanical_deficiencies"
          rows="3"
          required
          placeholder="Specify equipment type, observed performance issues, or compliance concern"
          class="w-full resize-none rounded-sm border border-light-grey/60 bg-white px-4 py-2.5 text-sm text-dark placeholder:text-slate/50 focus:border-primary focus:ring-2 focus:ring-primary/20 focus:outline-none"
        ></textarea>
      </div>

      <button
        type="submit"
        class="w-full rounded-sm bg-primary px-6 py-3 text-sm font-semibold tracking-wide text-white transition-colors hover:bg-primary/90"
      >
        Request Facility Assessment
      </button>
    </form>

    <!-- Footer trust signals -->
    <div class="mt-5 flex flex-col gap-2 text-xs text-slate sm:flex-row sm:items-center sm:justify-between">
      <span class="inline-flex items-center gap-1.5">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
        </svg>
        Restricted data handling. Technical queue only.
      </span>
      <span class="inline-flex items-center gap-1.5">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
        </svg>
        This submission is processed through a secured data channel.
      </span>
    </div>
  </div>
</div>

<script>
  const STORAGE_KEY = 'bam_exit_intent_v3';

  function wasAlreadyShown(): boolean {
    try {
      return sessionStorage.getItem(STORAGE_KEY) === '1';
    } catch {
      return false;
    }
  }

  function markAsShown(): void {
    try {
      sessionStorage.setItem(STORAGE_KEY, '1');
    } catch { /* private browsing */ }
  }

  function showModal(): void {
    if (wasAlreadyShown()) return;
    markAsShown();
    cleanup();

    const overlay = document.getElementById('exit-intent-overlay');
    if (!overlay) return;

    overlay.classList.remove('hidden');
    overlay.classList.add('flex');
    overlay.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }

  function closeModal(): void {
    const overlay = document.getElementById('exit-intent-overlay');
    if (!overlay) return;

    overlay.classList.add('hidden');
    overlay.classList.remove('flex');
    overlay.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  let timer: ReturnType<typeof setTimeout> | null = null;

  function handleMouseLeave(e: MouseEvent): void {
    if (e.clientY <= 0) showModal();
  }

  function cleanup(): void {
    document.removeEventListener('mouseleave', handleMouseLeave);
    if (timer) {
      clearTimeout(timer);
      timer = null;
    }
  }

  function init(): void {
    if (wasAlreadyShown()) return;

    document.addEventListener('mouseleave', handleMouseLeave);
    timer = setTimeout(showModal, 30_000);

    document.getElementById('exit-intent-close')?.addEventListener('click', closeModal);

    document.getElementById('exit-intent-overlay')?.addEventListener('click', (e) => {
      if ((e.target as HTMLElement).id === 'exit-intent-overlay') closeModal();
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeModal();
    });
  }

  init();
</script>
