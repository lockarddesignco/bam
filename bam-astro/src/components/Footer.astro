---
import { siteConfig } from '../config/site.config';

const currentYear = new Date().getFullYear();

const capabilities = [
  { label: 'Cooling Tower Restoration', href: '/services/cooling-tower/' },
  { label: 'Chiller Restoration', href: '/services/chiller/' },
  { label: 'AHU & Coil Restoration', href: '/services/ahu/' },
  { label: 'Indoor Air Quality', href: '/services/iaq/' },
  { label: 'Duct Cleaning', href: '/services/duct-cleaning/' },
  { label: 'Mold Remediation', href: '/services/mold-remediation/' },
  { label: 'Preventive Maintenance', href: '/services/preventive-maintenance/' },
  { label: 'Fire Damper Compliance', href: '/services/fire-damper-compliance/' },
  { label: 'All Services', href: '/services/', arrow: true },
];

const industries = [
  { label: 'Healthcare', href: '/industries/healthcare/' },
  { label: 'Education', href: '/industries/education/' },
  { label: 'Government & Secure', href: '/industries/government/' },
  { label: 'Data Centers', href: '/industries/data-centers/' },
  { label: 'Industrial', href: '/industries/industrial/' },
  { label: 'Commercial Real Estate', href: '/industries/commercial/' },
  { label: 'Food Processing', href: '/industries/food-processing/' },
  { label: 'Senior Living', href: '/industries/senior-care/' },
  { label: 'Labs & Life Sciences', href: '/industries/labs/' },
  { label: 'All Industries', href: '/industries/', arrow: true },
];

const stateLocations = siteConfig.locationStates.map(s => ({
  label: s.title,
  href: `/locations/${s.slug}/`,
}));

const metroLocations = siteConfig.locationMetros.map(m => ({
  label: m.title,
  href: `/locations/${m.slug}/`,
}));
---

<footer class="relative bg-primary text-ice border-t border-mint/20 overflow-hidden font-sans">
  <div class="absolute inset-0 opacity-[0.03] site-grid-dark"></div>

  <div class="relative z-10 max-w-[1440px] mx-auto px-6 md:px-12 lg:px-24 py-16 lg:py-20">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-12 gap-10 lg:gap-8">

      <!-- Column 1: Logo & Credentials -->
      <div class="flex flex-col items-start gap-5 lg:col-span-3">
        <a href="/" class="group no-underline">
          <img
            src="/bam-logo.webp"
            alt="BAM — Building & Air Maintenance"
            class="h-12 w-auto object-contain transition-transform duration-500 group-hover:rotate-180"
            width="48"
            height="48"
          />
        </a>

        <p class="text-light-grey text-sm leading-relaxed max-w-xs">
          Commercial HVAC restoration & IAQ for mission-critical facilities across PA, NJ, MD, DE, and Southern NY.
        </p>

        <div class="flex items-center gap-2 px-3 py-1.5 bg-[#1e483b] rounded-full border border-mint/20">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-mint"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>
          <span class="text-xs text-light-grey font-medium tracking-wide">NADCA & ASHRAE Member</span>
        </div>

        <div class="flex flex-col gap-2 pt-4 border-t border-mint/10 w-full">
          <span class="text-mint text-xs font-semibold uppercase tracking-wider">
            Verified Member — 21 Jan 2026
          </span>
          <div class="mt-2 w-full" style="max-width: 200px;">
            <div style="position: relative; width: 100%; padding-bottom: 71.3%;">
              <iframe
                style="border: 0; margin: 0; padding: 0; background-color: transparent; top: 0; left: 0; width: 100%; height: 100%; position: absolute;"
                src="https://cdn.yoshki.com/badge-nadca.html"
                frameborder="0"
                scrolling="no"
                title="NADCA Smart Badge"
                loading="lazy"
              ></iframe>
            </div>
          </div>
        </div>
      </div>

      <!-- Column 2: Capabilities -->
      <div class="lg:col-span-2">
        <h4 class="text-mint font-bold text-xs uppercase tracking-[0.15em] mb-5">Capabilities</h4>
        <ul class="space-y-2.5">
          {capabilities.map((item) => (
            <li>
              <a href={item.href} class="text-light-grey text-sm hover:text-white hover:translate-x-1 transition-all duration-200 inline-flex items-center no-underline">
                {item.label}{item.arrow ? ' →' : ''}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Column 3: Industries -->
      <div class="lg:col-span-2">
        <h4 class="text-mint font-bold text-xs uppercase tracking-[0.15em] mb-5">Industries</h4>
        <ul class="space-y-2.5">
          {industries.map((item) => (
            <li>
              <a href={item.href} class="text-light-grey text-sm hover:text-white hover:translate-x-1 transition-all duration-200 inline-flex items-center no-underline">
                {item.label}{item.arrow ? ' →' : ''}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Column 4: Locations -->
      <div class="lg:col-span-2">
        <h4 class="text-mint font-bold text-xs uppercase tracking-[0.15em] mb-5">States</h4>
        <ul class="space-y-2.5">
          {stateLocations.map((item) => (
            <li>
              <a href={item.href} class="text-light-grey text-sm hover:text-white hover:translate-x-1 transition-all duration-200 inline-flex items-center no-underline">
                {item.label}
              </a>
            </li>
          ))}
        </ul>

        <h4 class="text-mint font-bold text-xs uppercase tracking-[0.15em] mt-6 mb-5">Metros</h4>
        <ul class="space-y-2.5">
          {metroLocations.map((item) => (
            <li>
              <a href={item.href} class="text-light-grey text-sm hover:text-white hover:translate-x-1 transition-all duration-200 inline-flex items-center no-underline">
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Column 5: Contact -->
      <div class="flex flex-col items-start lg:col-span-3">
        <h4 class="text-mint font-bold text-xs uppercase tracking-[0.15em] mb-5">Contact</h4>

        <ul class="space-y-4 mb-6 w-full">
          <li class="flex items-start gap-3 text-light-grey">
            <div class="p-1.5 bg-[#1e483b] rounded-sm text-mint shrink-0 mt-0.5">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <span class="text-sm leading-relaxed">
              {siteConfig.mainAddress.street}, {siteConfig.mainAddress.city}, {siteConfig.mainAddress.state} {siteConfig.mainAddress.zip}
            </span>
          </li>
          <li class="flex items-center gap-3 text-light-grey">
            <div class="p-1.5 bg-[#1e483b] rounded-sm text-mint shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            </div>
            <a href={`tel:${siteConfig.phoneRaw}`} class="text-sm text-light-grey hover:text-white transition-colors font-medium no-underline">{siteConfig.phone}</a>
          </li>
          <li class="flex items-center gap-3 text-light-grey">
            <div class="p-1.5 bg-[#1e483b] rounded-sm text-mint shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            </div>
            <a href={`mailto:${siteConfig.email}`} class="text-sm text-light-grey hover:text-white transition-colors no-underline">{siteConfig.email}</a>
          </li>
        </ul>

        <a
          href="/contact/"
          class="inline-flex items-center justify-center whitespace-nowrap px-5 py-3 bg-mint text-primary font-bold text-sm tracking-wide rounded-sm shadow-[0_10px_30px_-10px_rgba(167,215,197,0.5)] hover:shadow-[0_20px_40px_-10px_rgba(167,215,197,0.6)] hover:-translate-y-0.5 transition-all duration-300 no-underline group"
        >
          Request a Site Visit
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ml-2 group-hover:translate-x-1 transition-transform"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>

    </div>
  </div>

  <!-- Bottom bar -->
  <div class="relative z-10 border-t border-mint/10 bg-[#1e483b]/30 backdrop-blur-sm">
    <div class="max-w-[1440px] mx-auto px-6 md:px-12 lg:px-24 py-4 flex flex-col md:flex-row justify-between items-center gap-3 text-xs text-light-grey/60">
      <p>&copy; {currentYear} Building & Air Maintenance, LLC. All rights reserved.</p>
      <div class="flex items-center gap-6 flex-wrap justify-center">
        <a href="/contact/" class="hover:text-mint transition-colors no-underline text-light-grey/60">Contact Support</a>
        <a href="/privacy/" class="hover:text-mint transition-colors no-underline text-light-grey/60">Privacy Policy</a>
        <div class="flex items-center gap-2">
          <div class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></div>
          <span>Systems Operational</span>
        </div>
        <a href="https://lockarddesignco.com" target="_blank" rel="noreferrer" class="text-light-grey/40 hover:text-mint transition-colors no-underline">Site by Lockard Design Co.</a>
      </div>
    </div>
  </div>
</footer>
