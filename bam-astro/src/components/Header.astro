---
import { siteConfig } from '../config/site.config';

const navItems = [
  { label: 'Services', href: '/services/', hasDropdown: true },
  { label: 'Industries', href: '/#industries', hasDropdown: true },
  { label: 'Locations', href: '/#locations', hasDropdown: true },
  { label: 'About', href: '/about/', hasDropdown: true },
  { label: 'Contact', href: '/contact/', hasDropdown: false },
];
---

<!-- Mobile utility bar — hides on scroll -->
<div id="utility-bar" class="w-full bg-[#080E0D] border-b border-white/[0.06] font-sans md:hidden">
  <div class="flex flex-col items-center py-2 gap-1.5">
    <div class="flex items-center justify-center gap-2">
      <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-mint flex-shrink-0"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
      <span class="text-[10px] font-semibold tracking-[0.15em] text-light-grey/70 uppercase">Serving PA · NJ · MD · DE · NY</span>
    </div>
    <div class="flex items-center justify-center gap-2">
      <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-mint flex-shrink-0"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/></svg>
      <span class="text-[10px] font-semibold tracking-[0.15em] text-light-grey/70 uppercase">Refurbishment ROI Estimator</span>
    </div>
    <div class="flex items-center justify-center gap-4">
      <div class="flex items-center gap-1">
        <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-mint/70 flex-shrink-0"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>
        <span class="text-[9px] font-semibold tracking-[0.1em] text-light-grey/50 uppercase">NADCA Certified</span>
      </div>
      <div class="flex items-center gap-1">
        <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-mint/70 flex-shrink-0"><path d="M17.7 7.7a2.5 2.5 0 1 1 1.8 4.3H2"/><path d="M9.6 4.6A2 2 0 1 1 11 8H2"/><path d="M12.6 19.4A2 2 0 1 0 14 16H2"/></svg>
        <span class="text-[9px] font-semibold tracking-[0.1em] text-light-grey/50 uppercase">ASHRAE Member</span>
      </div>
      <div class="flex items-center gap-1">
        <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-mint/70 flex-shrink-0"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
        <span class="text-[9px] font-semibold tracking-[0.1em] text-light-grey/50 uppercase">OSHA-30</span>
      </div>
    </div>
  </div>
</div>

<!-- Desktop utility bar (unchanged) -->
<div class="w-full bg-dark border-b border-primary/30 min-h-[36px] py-1.5 font-sans hidden md:flex items-center">
  <div class="w-full px-6 lg:px-12 flex items-center justify-between">
    <div class="flex items-center gap-3">
      <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-mint flex-shrink-0"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
      <span class="text-[11px] font-bold tracking-widest text-light-grey uppercase">Serving PA &bull; NJ &bull; MD &bull; DE &bull; NY</span>
      <div class="w-px h-3 bg-primary/50 hidden sm:block"></div>
      <a href="/tools/" class="hidden sm:flex items-center gap-1.5 text-[11px] font-bold tracking-widest text-light-grey uppercase hover:text-white transition-colors no-underline">
        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-mint flex-shrink-0"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/></svg>
        Refurbishment ROI Estimator
      </a>
    </div>
    <div class="flex items-center gap-5">
      <div class="flex items-center gap-1.5">
        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-mint flex-shrink-0"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>
        <span class="text-[10px] font-semibold tracking-wider text-slate uppercase">NADCA Certified</span>
      </div>
      <div class="w-px h-3 bg-primary/50"></div>
      <div class="flex items-center gap-1.5">
        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-mint flex-shrink-0"><path d="M17.7 7.7a2.5 2.5 0 1 1 1.8 4.3H2"/><path d="M9.6 4.6A2 2 0 1 1 11 8H2"/><path d="M12.6 19.4A2 2 0 1 0 14 16H2"/></svg>
        <span class="text-[10px] font-semibold tracking-wider text-slate uppercase">ASHRAE Member</span>
      </div>
      <div class="w-px h-3 bg-primary/50"></div>
      <div class="flex items-center gap-1.5">
        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-mint flex-shrink-0"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
        <span class="text-[10px] font-semibold tracking-wider text-slate uppercase">OSHA-30</span>
      </div>
      <div class="w-px h-3 bg-primary/50 hidden lg:block"></div>
      <span class="text-[10px] font-semibold tracking-wider text-mint uppercase hidden lg:inline">Resources</span>
    </div>
  </div>
</div>

<!-- Main header -->
<header id="main-header" class="sticky top-0 left-0 right-0 z-40 transition-all duration-300 border-b border-[#1e483b] bg-primary font-sans">
  <div class="w-full px-6 md:px-10 lg:px-12">
    <div class="flex items-center justify-between h-16 md:h-[72px]">

      <!-- Logo lockup -->
      <a href="/" class="flex items-center group no-underline flex-shrink-0">
        <img
          src="/bam-logo-v3.svg"
          alt="BAM Logo"
          class="w-10 h-10 md:w-12 md:h-12 object-contain flex-shrink-0 transition-transform duration-300 group-hover:scale-105"
        />
        <div class="h-8 w-px bg-mint/40 mx-3 md:mx-4 hidden sm:block"></div>
        <div class="flex flex-col justify-center hidden sm:flex">
          <span class="text-sm font-bold uppercase tracking-wide text-white leading-none">Building & Air</span>
          <span class="mt-1 text-[9px] font-semibold uppercase tracking-[0.35em] text-light-grey/70">Maintenance</span>
        </div>
      </a>

      <!-- Desktop nav -->
      <nav class="hidden xl:flex items-center gap-0.5">
        {navItems.map((item) => (
          <a
            href={item.href}
            class="flex items-center gap-1 px-3.5 py-2 text-[13px] font-bold text-light-grey hover:text-white transition-colors uppercase tracking-wide no-underline"
          >
            {item.label}
            {item.hasDropdown && (
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="opacity-50"><path d="m6 9 6 6 6-6"/></svg>
            )}
          </a>
        ))}
      </nav>

      <!-- Desktop CTA -->
      <div class="hidden xl:flex items-center gap-5 pl-5 ml-1 border-l border-mint/20">
        <a href={`tel:${siteConfig.phoneRaw}`} class="flex items-center gap-2 text-mint hover:text-white transition-colors font-bold text-sm no-underline">
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          <span>{siteConfig.phone}</span>
        </a>
        <a href="/contact/" class="inline-flex items-center justify-center px-5 py-2.5 border border-white/80 text-white font-bold text-[11px] uppercase tracking-widest rounded-sm hover:bg-white hover:text-primary transition-all no-underline">
          Request a Site Visit
        </a>
      </div>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        class="xl:hidden text-mint p-2 focus:outline-none hover:text-white transition-colors"
        aria-label="Toggle menu"
      >
        <svg id="menu-icon-open" xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="18" y2="18"/></svg>
        <svg id="menu-icon-close" xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="xl:hidden hidden absolute top-full left-0 w-full bg-primary border-t border-[#1e483b] overflow-y-auto max-h-[calc(100vh-64px)]">
    <div class="flex flex-col p-6 pb-24 space-y-2">
      {navItems.map((item) => (
        <a
          href={item.href}
          class="flex items-center justify-between py-4 text-lg font-bold text-white uppercase tracking-wider no-underline border-b border-[#1e483b]/50"
        >
          {item.label}
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-mint"><path d="m9 18 6-6-6-6"/></svg>
        </a>
      ))}
      <div class="pt-8 space-y-4">
        <a href={`tel:${siteConfig.phoneRaw}`} class="flex items-center justify-center gap-3 text-white font-bold text-base bg-[#1e483b] py-3.5 rounded-sm border border-mint/20 no-underline">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-mint"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          <span>{siteConfig.phone}</span>
        </a>
        <a href="/contact/" class="flex items-center justify-center w-full py-3.5 bg-white text-primary font-bold text-base uppercase tracking-widest rounded-sm shadow-lg no-underline">
          Request a Site Visit
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('menu-icon-open');
  const iconClose = document.getElementById('menu-icon-close');
  const header = document.getElementById('main-header');
  const utilityBar = document.getElementById('utility-bar');

  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
    iconOpen?.classList.toggle('hidden');
    iconClose?.classList.toggle('hidden');
  });

  window.addEventListener('scroll', () => {
    if (window.scrollY > 10) {
      header?.classList.add('backdrop-blur-md', 'shadow-lg');
      header?.style.setProperty('background-color', 'rgba(14, 59, 51, 0.95)');
      utilityBar?.classList.add('utility-bar-hidden');
    } else {
      header?.classList.remove('backdrop-blur-md', 'shadow-lg');
      header?.style.removeProperty('background-color');
      utilityBar?.classList.remove('utility-bar-hidden');
    }
  });
</script>

<style>
  #utility-bar {
    max-height: 80px;
    overflow: hidden;
    transition: max-height 0.3s ease, opacity 0.3s ease;
    opacity: 1;
  }
  #utility-bar.utility-bar-hidden {
    max-height: 0;
    opacity: 0;
  }
</style>
