                      <a href={`/locations/${loc.slug}/`} class="text-[14px] text-light-grey hover:text-white no-underline py-1.5">{loc.title}</a>
                    ))}
                    {siteConfig.locationMetros.map((loc) => (
                      <a href={`/locations/${loc.slug}/`} class="text-[14px] text-light-grey hover:text-white no-underline py-1.5">{loc.title}</a>
                    ))}
                  </>
                )}
                {item.label === 'About' && (
                  <>
                    <a href="/about/" class="text-[14px] text-light-grey hover:text-white no-underline py-1.5">About Overview</a>
                    <a href="/pilot-program/" class="text-[14px] text-light-grey hover:text-white no-underline py-1.5">Pilot Program</a>
                    <a href="/blog/" class="text-[14px] text-light-grey hover:text-white no-underline py-1.5">Blog & Insights</a>
                    <a href="/tools/" class="text-[14px] text-light-grey hover:text-white no-underline py-1.5">Tools & Calculators</a>
                  </>
                )}
              </div>
            </div>
          </div>
        ) : (
          <a
            href={item.href}
            class="flex items-center justify-between py-4 text-lg font-bold text-white uppercase tracking-wider no-underline border-b border-[#1e483b]/50"
          >
            {item.label}
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-mint"><path d="m9 18 6-6-6-6"/></svg>
          </a>
        )
      ))}
      <div class="pt-8 space-y-4">
        <a href={`tel:${siteConfig.phoneRaw}`} class="flex items-center justify-center gap-3 text-white font-bold text-base bg-[#1e483b] py-3.5 rounded-sm border border-mint/20 no-underline">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-mint"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          <span>{siteConfig.phone}</span>
        </a>
        <a href="/contact/" class="flex items-center justify-center w-full py-3.5 bg-white text-primary font-bold text-base uppercase tracking-widest rounded-sm shadow-lg no-underline">
          Request a Site Visit
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('menu-icon-open');
  const iconClose = document.getElementById('menu-icon-close');
  const header = document.getElementById('main-header');
  const utilityBar = document.getElementById('utility-bar');

  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
    iconOpen?.classList.toggle('hidden');
    iconClose?.classList.toggle('hidden');
  });

  const mobileDropdownButtons = document.querySelectorAll<HTMLButtonElement>('[data-mobile-dropdown-btn]');

  mobileDropdownButtons.forEach((button) => {
    button.addEventListener('click', () => {
      const key = button.dataset.mobileDropdownBtn;
      if (!key) return;

      const panel = document.querySelector<HTMLElement>(`[data-mobile-dropdown-panel="${key}"]`);
      const icon = document.querySelector<HTMLElement>(`[data-mobile-dropdown-icon="${key}"]`);
      const isOpen = panel ? !panel.classList.contains('hidden') : false;

      mobileDropdownButtons.forEach((otherButton) => {
        const otherKey = otherButton.dataset.mobileDropdownBtn;
        if (!otherKey) return;
        const otherPanel = document.querySelector<HTMLElement>(`[data-mobile-dropdown-panel="${otherKey}"]`);
        const otherIcon = document.querySelector<HTMLElement>(`[data-mobile-dropdown-icon="${otherKey}"]`);
        otherPanel?.classList.add('hidden');
        otherIcon?.classList.remove('rotate-180');
        otherButton.setAttribute('aria-expanded', 'false');
      });

      if (!isOpen) {
        panel?.classList.remove('hidden');
        icon?.classList.add('rotate-180');
        button.setAttribute('aria-expanded', 'true');
      }
    });
  });

  window.addEventListener('scroll', () => {
    if (window.scrollY > 10) {
      header?.classList.add('backdrop-blur-md', 'shadow-lg');
      header?.style.setProperty('background-color', 'rgba(14, 59, 51, 0.95)');
      utilityBar?.classList.add('utility-bar-hidden');
    } else {
      header?.classList.remove('backdrop-blur-md', 'shadow-lg');
      header?.style.removeProperty('background-color');
      utilityBar?.classList.remove('utility-bar-hidden');
    }
  });

  // Mega menu hover logic
  const triggers = document.querySelectorAll<HTMLElement>('.mega-trigger');
  let closeTimer: ReturnType<typeof setTimeout> | null = null;

  triggers.forEach(trigger => {
    const panel = trigger.querySelector<HTMLElement>('.mega-panel');
    const chevron = trigger.querySelector<HTMLElement>('.mega-chevron');
    if (!panel) return;

    function show() {
      if (closeTimer) { clearTimeout(closeTimer); closeTimer = null; }
      triggers.forEach(t => {
        const p = t.querySelector<HTMLElement>('.mega-panel');
        const c = t.querySelector<HTMLElement>('.mega-chevron');
        if (p && p !== panel) { p.classList.remove('mega-open'); p.classList.add('opacity-0', 'invisible'); p.classList.remove('opacity-100', 'visible'); }
        if (c && c !== chevron) c.classList.remove('rotate-180');
      });
      panel!.classList.add('mega-open', 'opacity-100', 'visible');
      panel!.classList.remove('opacity-0', 'invisible');
      chevron?.classList.add('rotate-180');
    }

    function hide() {
      closeTimer = setTimeout(() => {
        panel!.classList.remove('mega-open', 'opacity-100', 'visible');
        panel!.classList.add('opacity-0', 'invisible');
        chevron?.classList.remove('rotate-180');
      }, 150);
    }

    trigger.addEventListener('mouseenter', show);
    trigger.addEventListener('mouseleave', hide);
    panel.addEventListener('mouseenter', () => { if (closeTimer) { clearTimeout(closeTimer); closeTimer = null; } });
    panel.addEventListener('mouseleave', hide);
  });

  // Resources dropdown (utility bar)
  const resourcesTrigger = document.querySelector<HTMLElement>('.resources-trigger');
  const resourcesPanel = document.querySelector<HTMLElement>('.resources-panel');
  const resourcesChevron = document.querySelector<HTMLElement>('.resources-chevron');
  let resourcesCloseTimer: ReturnType<typeof setTimeout> | null = null;

  if (resourcesTrigger && resourcesPanel) {
    function showResources() {
      if (resourcesCloseTimer) { clearTimeout(resourcesCloseTimer); resourcesCloseTimer = null; }
      resourcesPanel.classList.add('opacity-100', 'visible');
      resourcesPanel.classList.remove('opacity-0', 'invisible');
      resourcesChevron?.classList.add('rotate-180');
      resourcesTrigger?.querySelector('button')?.setAttribute('aria-expanded', 'true');
    }
    function hideResources() {
      resourcesCloseTimer = setTimeout(() => {
        resourcesPanel.classList.remove('opacity-100', 'visible');
        resourcesPanel.classList.add('opacity-0', 'invisible');
        resourcesChevron?.classList.remove('rotate-180');
        resourcesTrigger?.querySelector('button')?.setAttribute('aria-expanded', 'false');
      }, 150);
    }
    resourcesTrigger.addEventListener('mouseenter', showResources);
    resourcesTrigger.addEventListener('mouseleave', hideResources);
    resourcesPanel.addEventListener('mouseenter', () => { if (resourcesCloseTimer) { clearTimeout(resourcesCloseTimer); resourcesCloseTimer = null; } });
    resourcesPanel.addEventListener('mouseleave', hideResources);
  }
</script>

<style>
  #utility-bar {
    max-height: 80px;
    overflow: hidden;
    transition: max-height 0.3s ease, opacity 0.3s ease;
    opacity: 1;
  }
  #utility-bar.utility-bar-hidden {
    max-height: 0;
    opacity: 0;
  }

  /* Resources dropdown — minimal text-only */
  .resources-dropdown-panel {
    background-color: #0B1110;
    border: 1px solid rgba(167, 215, 197, 0.15);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.4);
  }
  .resources-link {
    color: #9EABA4;
  }
  .resources-link:hover {
    color: #ffffff;
    padding-left: 18px;
  }
  .resources-link-all {
    color: #A7D7C5;
    font-weight: 600;
    letter-spacing: 0.02em;
  }
  .resources-link-all:hover {
    color: #ffffff;
  }
  .resources-separator {
    height: 1px;
    background-color: rgba(167, 215, 197, 0.12);
  }
</style>
