---
import { siteConfig } from '../config/site.config';
---

<div class="fixed bottom-0 left-0 right-0 z-50 lg:hidden bg-dark border-t border-mint/20 safe-area-pb">
  <div class="grid grid-cols-3 h-[60px]">
    <a
      href={`tel:${siteConfig.phoneRaw}`}
      class="flex flex-col items-center justify-center gap-1 text-light-grey hover:text-white active:text-mint transition-colors no-underline"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-mint"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
      <span class="text-[10px] font-bold uppercase tracking-wider">Call</span>
    </a>

    <a
      href="/contact/"
      class="flex items-center justify-center bg-primary mx-2 my-1.5 rounded-sm no-underline"
    >
      <span class="text-white text-[11px] font-bold uppercase tracking-widest">Site Visit</span>
    </a>

    <a
      href="/services/"
      class="flex flex-col items-center justify-center gap-1 text-light-grey hover:text-white active:text-mint transition-colors no-underline"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-mint"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
      <span class="text-[10px] font-bold uppercase tracking-wider">Services</span>
    </a>
  </div>
</div>

<style>
  .safe-area-pb {
    padding-bottom: env(safe-area-inset-bottom, 0px);
  }
</style>
