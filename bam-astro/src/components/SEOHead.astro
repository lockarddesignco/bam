---
import { siteConfig } from '../config/site.config';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonicalURL?: string;
  type?: 'website' | 'article';
  locationData?: {
    city: string;
    state: string;
    address?: string;
    zip: string;
    lat: number;
    lng: number;
    phone?: string;
    intro?: string;
  };
  serviceData?: {
    name: string;
    description: string;
  };
  faqData?: Array<{ question: string; answer: string }>;
  articleData?: {
    datePublished: string;
    dateModified?: string;
    author: string;
    section?: string;
  };
  breadcrumbs?: Array<{ name: string; url: string }>;
  noindex?: boolean;
}

const {
  title = siteConfig.title,
  description = siteConfig.description,
  image = siteConfig.ogImage,
  canonicalURL = new URL(Astro.url.pathname, Astro.site).toString(),
  type = 'website',
  locationData,
  serviceData,
  faqData,
  articleData,
  breadcrumbs,
  noindex = false,
} = Astro.props;

const sameAsLinks = [
  ...siteConfig.socialLinks,
  siteConfig.gbpReviewLink,
  siteConfig.googleBusinessUrl,
];

const imageUrl = new URL(image, Astro.site).toString();

const graphEntities: Record<string, unknown>[] = [
  {
    '@type': 'Organization',
    '@id': `${Astro.site}#organization`,
    name: siteConfig.businessName,
    url: Astro.site,
    logo: new URL(siteConfig.logo, Astro.site).toString(),
    telephone: siteConfig.phone,
    email: siteConfig.email,
    sameAs: sameAsLinks,
  },
  {
    '@type': 'WebSite',
    '@id': `${Astro.site}#website`,
    url: Astro.site,
    name: siteConfig.businessName,
    publisher: { '@id': `${Astro.site}#organization` },
  },
];

if (locationData) {
  graphEntities.push({
    '@type': 'ServiceAreaBusiness',
    '@id': `${canonicalURL}#localbusiness`,
    name: siteConfig.businessName,
    alternateName: `${siteConfig.businessName} — ${locationData.city}, ${locationData.state}`,
    description: locationData.intro || description,
    url: canonicalURL,
    telephone: locationData.phone || siteConfig.phone,
    email: siteConfig.email,
    sameAs: sameAsLinks,
    parentOrganization: { '@id': `${Astro.site}#organization` },
    address: {
      '@type': 'PostalAddress',
      streetAddress: locationData.address || '',
      addressLocality: locationData.city,
      addressRegion: locationData.state,
      postalCode: locationData.zip,
      addressCountry: 'US',
    },
    geo: {
      '@type': 'GeoCoordinates',
      latitude: locationData.lat,
      longitude: locationData.lng,
    },
    areaServed: {
      '@type': 'City',
      name: locationData.city,
      containedInPlace: {
        '@type': 'State',
        name: locationData.state,
      },
    },
    priceRange: '$$',
    image: imageUrl,
    hasOfferCatalog: {
      '@type': 'OfferCatalog',
      name: 'HVAC Services',
      itemListElement: siteConfig.services.map((s) => ({
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: s.title,
          url: new URL(`/services/${s.slug}/`, Astro.site).toString(),
        },
      })),
    },
  });
} else {
  graphEntities.push({
    '@type': 'ServiceAreaBusiness',
    '@id': `${Astro.site}#localbusiness`,
    name: siteConfig.businessName,
    description: siteConfig.description,
    url: Astro.site,
    telephone: siteConfig.phone,
    email: siteConfig.email,
    sameAs: sameAsLinks,
    parentOrganization: { '@id': `${Astro.site}#organization` },
    address: {
      '@type': 'PostalAddress',
      streetAddress: siteConfig.mainAddress.street,
      addressLocality: siteConfig.mainAddress.city,
      addressRegion: siteConfig.mainAddress.state,
      postalCode: siteConfig.mainAddress.zip,
      addressCountry: siteConfig.mainAddress.country,
    },
    geo: {
      '@type': 'GeoCoordinates',
      latitude: siteConfig.geo.lat,
      longitude: siteConfig.geo.lng,
    },
    areaServed: siteConfig.serviceAreas.map((area) => ({
      '@type': 'AdministrativeArea',
      name: area,
    })),
    priceRange: '$$',
    image: imageUrl,
    founder: {
      '@type': 'Person',
      name: siteConfig.owner,
    },
    hasOfferCatalog: {
      '@type': 'OfferCatalog',
      name: 'HVAC Services',
      itemListElement: siteConfig.services.map((s) => ({
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: s.title,
          url: new URL(`/services/${s.slug}/`, Astro.site).toString(),
        },
      })),
    },
  });
}

if (serviceData) {
  graphEntities.push({
    '@type': 'Service',
    '@id': `${canonicalURL}#service`,
    name: serviceData.name,
    description: serviceData.description,
    provider: { '@id': `${Astro.site}#localbusiness` },
    areaServed: siteConfig.serviceAreas.map((area) => ({
      '@type': 'AdministrativeArea',
      name: area,
    })),
  });
}

if (faqData && faqData.length > 0) {
  graphEntities.push({
    '@type': 'FAQPage',
    '@id': `${canonicalURL}#faq`,
    mainEntity: faqData.map((faq) => ({
      '@type': 'Question',
      name: faq.question,
      acceptedAnswer: {
        '@type': 'Answer',
        text: faq.answer,
      },
    })),
  });
}

if (articleData) {
  graphEntities.push({
    '@type': 'Article',
    '@id': `${canonicalURL}#article`,
    headline: title,
    description: description,
    datePublished: articleData.datePublished,
    ...(articleData.dateModified && { dateModified: articleData.dateModified }),
    author: {
      '@type': 'Organization',
      name: articleData.author,
      url: Astro.site,
    },
    publisher: { '@id': `${Astro.site}#organization` },
    image: imageUrl,
    mainEntityOfPage: canonicalURL,
    ...(articleData.section && { articleSection: articleData.section }),
  });
}

if (breadcrumbs && breadcrumbs.length > 0) {
  const items = [
    { '@type': 'ListItem', position: 1, name: 'Home', item: Astro.site?.toString().replace(/\/$/, '') || '' },
    ...breadcrumbs.map((crumb, i) => ({
      '@type': 'ListItem',
      position: i + 2,
      name: crumb.name,
      item: new URL(crumb.url, Astro.site).toString(),
    })),
  ];
  graphEntities.push({
    '@type': 'BreadcrumbList',
    '@id': `${canonicalURL}#breadcrumb`,
    itemListElement: items,
  });
}

const schema = {
  '@context': 'https://schema.org',
  '@graph': graphEntities,
};
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<link rel="icon" href="/favicon.svg" type="image/svg+xml" />
<link rel="icon" href="/favicon-32x32.png" type="image/png" sizes="32x32" />
<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
<link rel="manifest" href="/site.webmanifest" />
<link rel="canonical" href={canonicalURL} />

<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />
<meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow'} />

<meta property="og:type" content={type} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={imageUrl} />
<meta property="og:site_name" content={siteConfig.businessName} />

{articleData && (
  <>
    <meta property="article:published_time" content={articleData.datePublished} />
    <meta property="article:author" content={articleData.author} />
    {articleData.section && <meta property="article:section" content={articleData.section} />}
  </>
)}

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={imageUrl} />

<script type="application/ld+json" set:html={JSON.stringify(schema)} />
