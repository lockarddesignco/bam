---
import BaseLayout from './BaseLayout.astro';
import { siteConfig } from '../config/site.config';

interface Props {
  title: string;
  description: string;
  metroName: string;
  heroBody: string;
  ctaBadge: string;
  whoServes: string;
  scenarios: string[];
  facilityTypes: string[];
  govRedirectLabel: string;
  govRedirectHref: string;
  workflowSteps: Array<{ step: string; title: string; desc: string }>;
  capabilitiesTitle: string;
  capabilitiesBody: string;
  capabilities: Array<{ title: string; icon: string; items: string[] }>;
  safetyTitle: string;
  safetyBody: string;
  safetyCards: Array<{ title: string; body: string; icon: string }>;
  serviceArea: Array<{ label: string; value: string }>;
  mapQuery: string;
  ctaTitle: string;
  ctaBody: string;
}

const props = Astro.props;
---

<BaseLayout title={props.title} description={props.description}>

<!-- Hero -->
<section class="relative pt-32 pb-20 md:pt-40 md:pb-28 bg-[#1A1F1E] overflow-hidden">
  <div class="absolute inset-0 opacity-[0.03] pointer-events-none" style="background-image: linear-gradient(#A7D7C5 1px, transparent 1px), linear-gradient(90deg, #A7D7C5 1px, transparent 1px); background-size: 40px 40px;"></div>

  <div class="relative z-10 max-w-[1440px] mx-auto px-6 md:px-12 lg:px-24">
    <div class="max-w-3xl">
      <div class="inline-flex items-center gap-2 text-mint mb-6">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="3 11 22 2 13 21 11 13 3 11"/></svg>
        <span class="text-[10px] font-bold uppercase tracking-[0.2em]">Metro Execution Zone</span>
      </div>
      <h1 class="text-4xl md:text-6xl font-black text-white leading-tight tracking-tighter mb-6">
        {props.metroName}<br/>
        <span class="text-mint">Regional Operations</span>
      </h1>
      <p class="text-light-grey text-lg font-light leading-relaxed border-l-2 border-mint pl-6 opacity-90 max-w-xl mb-8">
        {props.heroBody}
      </p>
      <div class="flex flex-col sm:flex-row items-center gap-6">
        <a href="/contact/" class="inline-flex items-center justify-center px-8 py-4 bg-white text-primary font-bold text-sm uppercase tracking-widest rounded-sm hover:bg-mint transition-colors no-underline">
          Schedule Site Scout
        </a>
        <div class="flex items-center gap-2 text-xs font-bold text-light-grey uppercase tracking-widest">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-mint"><rect width="20" height="14" x="2" y="5" rx="2"/><path d="M2 10h20"/></svg>
          <span>{props.ctaBadge}</span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Who This Zone Serves -->
<section class="py-20 md:py-28 bg-white border-b border-light-grey/40">
  <div class="max-w-[1440px] mx-auto px-6 md:px-12 lg:px-24">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
      <div>
        <h2 class="text-3xl font-bold text-primary mb-6">Who This Zone Serves</h2>
        <p class="text-slate text-lg font-light leading-relaxed mb-8">
          {props.whoServes}
        </p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div class="p-4 bg-offwhite border border-light-grey/60 rounded-sm">
            <h4 class="font-bold text-primary text-xs uppercase tracking-widest mb-3">Operational Scenarios</h4>
            <ul class="text-xs text-slate space-y-2">
              {props.scenarios.map(s => <li>&bull; {s}</li>)}
            </ul>
          </div>
          <div class="p-4 bg-offwhite border border-light-grey/60 rounded-sm">
            <h4 class="font-bold text-primary text-xs uppercase tracking-widest mb-3">Facility Types</h4>
            <ul class="text-xs text-slate space-y-2">
              {props.facilityTypes.map(f => <li>&bull; {f}</li>)}
            </ul>
          </div>
        </div>
      </div>
      <div class="bg-primary p-10 text-white rounded-sm flex flex-col justify-center relative overflow-hidden">
        <div class="absolute top-0 right-0 p-6 opacity-10">
          <svg xmlns="http://www.w3.org/2000/svg" width="96" height="96" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="0.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 7h10v10"/><path d="M7 17 17 7"/></svg>
        </div>
        <div class="relative z-10">
          <h3 class="text-lg font-bold mb-4">Not a Site Manager?</h3>
          <p class="text-light-grey text-sm leading-relaxed mb-6">
            If you are a <strong class="text-white">Director of Facilities</strong> or <strong class="text-white">Procurement Officer</strong> managing a multi-site portfolio, please proceed to the State Authority page.
          </p>
          <a href={props.govRedirectHref} class="inline-flex items-center justify-center px-6 py-3 border border-white/30 text-white font-bold text-xs uppercase tracking-widest rounded-sm hover:bg-white/10 transition-colors no-underline">
            {props.govRedirectLabel}
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Coordination Workflow -->
<section class="py-20 md:py-28 bg-offwhite border-b border-light-grey/40">
  <div class="max-w-[1440px] mx-auto px-6 md:px-12 lg:px-24">
    <div class="text-center mb-16">
      <h2 class="text-3xl font-bold text-primary mb-4">Metro Coordination Workflow</h2>
      <p class="text-slate">Standard operating procedure for local site engagements.</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
      {props.workflowSteps.map(item => (
        <div class="bg-white p-6 border border-light-grey/60 rounded-sm">
          <div class="w-10 h-10 bg-primary text-white flex items-center justify-center font-bold text-sm mb-4 rounded-sm">{item.step}</div>
          <h4 class="font-bold text-primary text-sm uppercase tracking-widest mb-3">{item.title}</h4>
          <p class="text-xs text-slate leading-relaxed">{item.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Execution Capabilities -->
<section class="py-20 md:py-28 bg-white">
  <div class="max-w-[1440px] mx-auto px-6 md:px-12 lg:px-24">
    <div class="mb-12">
      <h2 class="text-3xl font-bold text-primary mb-6">{props.capabilitiesTitle}</h2>
      <p class="text-slate max-w-3xl leading-relaxed">{props.capabilitiesBody}</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {props.capabilities.map(cap => (
        <div class="border border-light-grey/60 p-8 hover:border-primary/30 transition-colors rounded-sm">
          <Fragment set:html={cap.icon} />
          <h4 class="font-bold text-primary text-sm uppercase tracking-widest mb-4 mt-6">{cap.title}</h4>
          <ul class="space-y-3 text-sm text-slate">
            {cap.items.map(item => (
              <li class="flex gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-mint shrink-0"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>
                {item}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Safety & Service Area -->
<section class="py-20 md:py-28 bg-offwhite border-t border-light-grey/40">
  <div class="max-w-[1440px] mx-auto px-6 md:px-12 lg:px-24">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      <div>
        <h2 class="text-3xl font-bold text-primary mb-6">{props.safetyTitle}</h2>
        <p class="text-slate leading-relaxed mb-6">{props.safetyBody}</p>
        <div class="space-y-4">
          {props.safetyCards.map(card => (
            <div class="flex gap-4 p-4 bg-white border border-light-grey/60 rounded-sm">
              <Fragment set:html={card.icon} />
              <div>
                <h4 class="font-bold text-primary text-xs uppercase tracking-widest">{card.title}</h4>
                <p class="text-sm text-slate">{card.body}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
      <div class="space-y-6">
        <div class="relative h-[280px] md:h-[320px] rounded-sm overflow-hidden">
          <iframe
            title={`${props.metroName} Service Area`}
            width="100%"
            height="100%"
            style="border:0;"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            src={`https://www.google.com/maps/embed/v1/place?key=AIzaSyBFw0Qbyq9zTFTd-tUY6dZWTgaQzuU17R8&q=${encodeURIComponent(props.mapQuery)}&zoom=11`}
          ></iframe>
        </div>
        <div class="bg-white p-6 border border-light-grey/60 shadow-sm rounded-sm">
          <h4 class="font-bold text-primary text-sm uppercase tracking-widest mb-4">Service Area Details</h4>
          <ul class="space-y-3 text-sm text-slate">
            {props.serviceArea.map(area => (
              <li class="flex items-start gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-mint mt-0.5 shrink-0"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                <span><strong class="text-primary">{area.label}:</strong> {area.value}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="py-20 md:py-28 bg-[#1A1F1E] border-t border-mint/10">
  <div class="max-w-4xl mx-auto px-6 text-center">
    <h2 class="text-3xl font-bold text-white mb-6">{props.ctaTitle}</h2>
    <p class="text-light-grey mb-10 max-w-lg mx-auto">{props.ctaBody}</p>
    <div class="flex flex-col sm:flex-row justify-center gap-6">
      <a href="/contact/" class="inline-flex items-center justify-center px-8 py-4 bg-white text-primary font-bold text-sm uppercase tracking-widest rounded-sm hover:bg-mint transition-colors no-underline">
        Request Site Scout
      </a>
      <a href={`tel:${siteConfig.phoneRaw}`} class="flex items-center justify-center gap-2 text-white font-bold border border-white/20 px-8 py-3 rounded-sm hover:bg-white/10 transition-colors no-underline">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        <span>{siteConfig.phone}</span>
      </a>
    </div>
  </div>
</section>

</BaseLayout>
