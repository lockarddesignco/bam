---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Page Not Found | BAM" description="The page you're looking for could not be found.">
  <section class="py-16 md:py-24 px-6 min-h-[70vh] flex flex-col items-center justify-center bg-ice relative overflow-hidden">

    <div class="tv-wrapper">
      <div class="tv-main">
        <div class="tv-antenna">
          <div class="tv-antenna-shadow"></div>
          <div class="tv-a1"></div>
          <div class="tv-a1d"></div>
          <div class="tv-a2"></div>
          <div class="tv-a2d"></div>
        </div>
        <div class="tv-body">
          <div class="tv-cruve">
            <svg
              class="tv-curve-svg"
              version="1.1"
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 189.929 189.929"
            >
              <path
                d="M70.343,70.343c-30.554,30.553-44.806,72.7-39.102,115.635l-29.738,3.951C-5.442,137.659,11.917,86.34,49.129,49.13
                C86.34,11.918,137.664-5.445,189.928,1.502l-3.95,29.738C143.041,25.54,100.895,39.789,70.343,70.343z"
              ></path>
            </svg>
          </div>
          <div class="tv-display">
            <div class="tv-screen-out">
              <div class="tv-screen-out1">
                <div class="tv-screen">
                  <span class="tv-notfound-text">NOT FOUND</span>
                </div>
                <div class="tv-screenM">
                  <span class="tv-notfound-text">NOT FOUND</span>
                </div>
              </div>
            </div>
          </div>
          <div class="tv-lines">
            <div class="tv-line1"></div>
            <div class="tv-line2"></div>
            <div class="tv-line3"></div>
          </div>
          <div class="tv-buttons">
            <div class="tv-b1"><div></div></div>
            <div class="tv-b2"></div>
            <div class="tv-speakers">
              <div class="tv-g1">
                <div class="tv-g11"></div>
                <div class="tv-g12"></div>
                <div class="tv-g13"></div>
              </div>
              <div class="tv-g"></div>
              <div class="tv-g"></div>
            </div>
          </div>
        </div>
        <div class="tv-bottom">
          <div class="tv-base1"></div>
          <div class="tv-base2"></div>
          <div class="tv-base3"></div>
        </div>
      </div>
      <div class="tv-text-404">
        <div class="tv-text-4041">4</div>
        <div class="tv-text-4042">0</div>
        <div class="tv-text-4043">4</div>
      </div>
    </div>

    <div class="text-center mt-10 relative z-10">
      <p class="text-slate text-lg mb-6 max-w-md mx-auto">
        The page you're looking for doesn't exist or has been moved.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="/"
          class="inline-flex items-center gap-2 bg-primary text-white px-6 py-3 font-bold text-sm tracking-wide rounded-sm hover:bg-primary/90 transition-colors no-underline"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
          Back to Home
        </a>
        <a
          href="/contact/"
          class="inline-flex items-center gap-2 border-2 border-primary text-primary px-6 py-3 font-bold text-sm tracking-wide rounded-sm hover:bg-primary hover:text-white transition-colors no-underline"
        >
          Contact Us
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .tv-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 30em;
    height: 30em;
  }

  .tv-main {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    margin-top: 5em;
  }

  /* Antenna ball — primary green */
  .tv-antenna {
    width: 5em;
    height: 5em;
    border-radius: 50%;
    border: 2px solid #1a3d31;
    background-color: #265A4A;
    margin-bottom: -6em;
    z-index: -1;
  }
  .tv-antenna-shadow {
    position: absolute;
    background-color: transparent;
    width: 50px;
    height: 56px;
    margin-left: 1.68em;
    border-radius: 45%;
    transform: rotate(140deg);
    border: 4px solid transparent;
    box-shadow:
      inset 0px 16px #1a3d31,
      inset 0px 16px 1px 1px #1a3d31;
  }
  .tv-antenna::after {
    content: "";
    position: absolute;
    margin-top: -9.4em;
    margin-left: 0.4em;
    transform: rotate(-25deg);
    width: 1em;
    height: 0.5em;
    border-radius: 50%;
    background-color: #A7D7C5;
  }
  .tv-antenna::before {
    content: "";
    position: absolute;
    margin-top: 0.2em;
    margin-left: 1.25em;
    transform: rotate(-20deg);
    width: 1.5em;
    height: 0.8em;
    border-radius: 50%;
    background-color: #A7D7C5;
  }

  /* Antenna arms */
  .tv-a1 {
    position: relative;
    top: -102%;
    left: -130%;
    width: 12em;
    height: 5.5em;
    border-radius: 50px;
    background-image: linear-gradient(#171717, #171717, #353535, #353535, #171717);
    transform: rotate(-29deg);
    clip-path: polygon(50% 0%, 49% 100%, 52% 100%);
  }
  .tv-a1d {
    position: relative;
    top: -211%;
    left: -35%;
    transform: rotate(45deg);
    width: 0.5em;
    height: 0.5em;
    border-radius: 50%;
    border: 2px solid #1a3d31;
    background-color: #5E7A86;
    z-index: 99;
  }
  .tv-a2 {
    position: relative;
    top: -210%;
    left: -10%;
    width: 12em;
    height: 4em;
    border-radius: 50px;
    background-image: linear-gradient(#171717, #171717, #353535, #353535, #171717);
    margin-right: 5em;
    clip-path: polygon(47% 0, 47% 0, 34% 34%, 54% 25%, 32% 100%, 29% 96%, 49% 32%, 30% 38%);
    transform: rotate(-8deg);
  }
  .tv-a2d {
    position: relative;
    top: -294%;
    left: 94%;
    width: 0.5em;
    height: 0.5em;
    border-radius: 50%;
    border: 2px solid #1a3d31;
    background-color: #5E7A86;
    z-index: 99;
  }

  /* "NOT FOUND" label */
  .tv-notfound-text {
    background-color: #0B1110;
    padding: 0.15em 0.4em;
    font-size: 0.75em;
    color: white;
    letter-spacing: 0;
    border-radius: 5px;
    z-index: 10;
  }

  /* TV body — green themed */
  .tv-body {
    width: 17em;
    height: 9em;
    margin-top: 3em;
    border-radius: 15px;
    background-color: #265A4A;
    display: flex;
    justify-content: center;
    border: 2px solid #1a3d31;
    box-shadow: inset 0.2em 0.2em #3d8b6e;
  }
  .tv-body::after {
    content: "";
    position: absolute;
    width: 17em;
    height: 9em;
    border-radius: 15px;
    background:
      repeating-radial-gradient(#265A4A 0 0.0001%, #00000070 0 0.0002%) 50% 0/2500px 2500px,
      repeating-conic-gradient(#265A4A 0 0.0001%, #00000070 0 0.0002%) 60% 60%/2500px 2500px;
    background-blend-mode: difference;
    opacity: 0.09;
  }

  .tv-curve-svg {
    position: absolute;
    margin-top: 0.25em;
    margin-left: -0.25em;
    height: 12px;
    width: 12px;
  }

  .tv-display {
    display: flex;
    align-items: center;
    align-self: center;
    justify-content: center;
    border-radius: 15px;
    box-shadow: 3.5px 3.5px 0px #3d8b6e;
  }

  .tv-screen-out {
    width: auto;
    height: auto;
    border-radius: 10px;
  }
  .tv-screen-out1 {
    width: 11em;
    height: 7.75em;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 10px;
  }

  /* Static noise screen */
  .tv-screen {
    width: 13em;
    height: 7.85em;
    font-family: 'Inter', sans-serif;
    border: 2px solid #1a3d31;
    background:
      repeating-radial-gradient(#000 0 0.0001%, #ffffff 0 0.0002%) 50% 0/2500px 2500px,
      repeating-conic-gradient(#000 0 0.0001%, #ffffff 0 0.0002%) 60% 60%/2500px 2500px;
    background-blend-mode: difference;
    animation: tv-static 0.2s infinite alternate;
    border-radius: 10px;
    z-index: 99;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: bold;
    color: #252525;
    letter-spacing: 0.15em;
    text-align: center;
  }

  /* Color bars screen (mobile) */
  .tv-screenM {
    width: 13em;
    height: 7.85em;
    position: relative;
    font-family: 'Inter', sans-serif;
    background: linear-gradient(
      to right,
      #265A4A 0%, #1a3d31 14.29%,
      #3a3a3a 14.29%, #303030 28.57%,
      #A7D7C5 28.57%, #8ec4ae 42.86%,
      #6c6c6c 42.86%, #626262 57.14%,
      #5E7A86 57.14%, #4d6970 71.43%,
      #3a3a3a 71.43%, #303030 85.71%,
      #F7F9F8 85.71%, #eef2ef 100%
    );
    border-radius: 10px;
    border: 2px solid #1a3d31;
    z-index: 99;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: bold;
    color: #252525;
    letter-spacing: 0.15em;
    text-align: center;
    overflow: hidden;
  }
  .tv-screenM:before,
  .tv-screenM:after {
    content: "";
    position: absolute;
    left: 0;
    z-index: 1;
    width: 100%;
  }
  .tv-screenM:before {
    top: 0;
    height: 68.48%;
    background: linear-gradient(
      to right,
      #F7F9F8 0%, #eef2ef 14.29%,
      #A7D7C5 14.29%, #8ec4ae 28.57%,
      #5E7A86 28.57%, #4d6970 42.86%,
      #265A4A 42.86%, #1a3d31 57.14%,
      #D7DDDA 57.14%, #c5cdc8 71.43%,
      #0B1110 71.43%, #060807 85.71%,
      #265A4A 85.71%, #1a3d31 100%
    );
  }
  .tv-screenM:after {
    bottom: 0;
    height: 21.74%;
    background: linear-gradient(
      to right,
      #1a3d31 0%, #132b23 16.67%,
      #F7F9F8 16.67%, #eef2ef 33.33%,
      #0B1110 33.33%, #060807 50%,
      #6c6c6c 50%, #626262 66.67%,
      #929292 66.67%, #888888 83.33%,
      #3a3a3a 83.33%, #303030 100%
    );
  }

  @keyframes tv-static {
    100% {
      background-position: 50% 0, 60% 50%;
    }
  }

  /* Lines on TV side */
  .tv-lines {
    display: flex;
    column-gap: 0.1em;
    align-self: flex-end;
  }
  .tv-line1,
  .tv-line3 {
    width: 2px;
    height: 0.5em;
    background-color: #0B1110;
    border-radius: 25px 25px 0 0;
    margin-top: 0.5em;
  }
  .tv-line2 {
    flex-grow: 1;
    width: 2px;
    height: 1em;
    background-color: #0B1110;
    border-radius: 25px 25px 0 0;
  }

  /* Buttons panel — lighter green */
  .tv-buttons {
    width: 4.25em;
    align-self: center;
    height: 8em;
    background-color: #3d8b6e;
    border: 2px solid #1a3d31;
    padding: 0.6em;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    row-gap: 0.75em;
    box-shadow: 3px 3px 0px #3d8b6e;
  }
  .tv-b1 {
    width: 1.65em;
    height: 1.65em;
    border-radius: 50%;
    background-color: #1a3d31;
    border: 2px solid #0B1110;
    box-shadow:
      inset 2px 2px 1px #265A4A,
      -2px 0px #0B1110,
      -2px 0px 0px 1px #0B1110;
  }
  .tv-b1::before {
    content: "";
    position: absolute;
    margin-top: 1em;
    margin-left: 0.5em;
    transform: rotate(47deg);
    border-radius: 5px;
    width: 0.1em;
    height: 0.4em;
    background-color: #000;
  }
  .tv-b1::after {
    content: "";
    position: absolute;
    margin-top: 0.9em;
    margin-left: 0.8em;
    transform: rotate(47deg);
    border-radius: 5px;
    width: 0.1em;
    height: 0.55em;
    background-color: #000;
  }
  .tv-b1 div {
    position: absolute;
    margin-top: -0.1em;
    margin-left: 0.65em;
    transform: rotate(45deg);
    width: 0.15em;
    height: 1.5em;
    background-color: #000;
  }
  .tv-b2 {
    width: 1.65em;
    height: 1.65em;
    border-radius: 50%;
    background-color: #1a3d31;
    border: 2px solid #0B1110;
    box-shadow:
      inset 2px 2px 1px #265A4A,
      -2px 0px #0B1110,
      -2px 0px 0px 1px #0B1110;
  }
  .tv-b2::before {
    content: "";
    position: absolute;
    margin-top: 1.05em;
    margin-left: 0.8em;
    transform: rotate(-45deg);
    border-radius: 5px;
    width: 0.15em;
    height: 0.4em;
    background-color: #000;
  }
  .tv-b2::after {
    content: "";
    position: absolute;
    margin-top: -0.1em;
    margin-left: 0.65em;
    transform: rotate(-45deg);
    width: 0.15em;
    height: 1.5em;
    background-color: #000;
  }

  /* Speaker grills */
  .tv-speakers {
    display: flex;
    flex-direction: column;
    row-gap: 0.5em;
  }
  .tv-speakers .tv-g1 {
    display: flex;
    column-gap: 0.25em;
  }
  .tv-speakers .tv-g1 .tv-g11,
  .tv-g12,
  .tv-g13 {
    width: 0.65em;
    height: 0.65em;
    border-radius: 50%;
    background-color: #1a3d31;
    border: 2px solid #0B1110;
    box-shadow: inset 1.25px 1.25px 1px #265A4A;
  }
  .tv-speakers .tv-g {
    width: auto;
    height: 2px;
    background-color: #171717;
  }

  /* Base / legs */
  .tv-bottom {
    width: 100%;
    height: auto;
    display: flex;
    align-items: center;
    justify-content: center;
    column-gap: 8.7em;
  }
  .tv-base1,
  .tv-base2 {
    height: 1em;
    width: 2em;
    border: 2px solid #171717;
    background-color: #4d4d4d;
    margin-top: -0.15em;
    z-index: -1;
  }
  .tv-base3 {
    position: absolute;
    height: 0.15em;
    width: 17.5em;
    background-color: #171717;
    margin-top: 0.8em;
  }

  /* Background 404 text */
  .tv-text-404 {
    position: absolute;
    display: flex;
    flex-direction: row;
    column-gap: 6em;
    z-index: -5;
    margin-bottom: 2em;
    align-items: center;
    justify-content: center;
    opacity: 0.07;
    font-family: 'Inter', sans-serif;
    color: #265A4A;
  }
  .tv-text-4041,
  .tv-text-4043 {
    transform: scaleY(24.5) scaleX(9);
  }
  .tv-text-4042 {
    transform: scaleY(24.5) scaleX(9);
  }

  @media only screen and (max-width: 495px) {
    .tv-text-404 { column-gap: 6em; }
  }
  @media only screen and (max-width: 395px) {
    .tv-text-404 { column-gap: 4em; }
    .tv-text-4041,
    .tv-text-4042,
    .tv-text-4043 {
      transform: scaleY(25) scaleX(8);
    }
  }
  @media (max-width: 275px), (max-height: 520px) {
    .tv-main { position: relative; }
  }

  @media only screen and (max-width: 1024px) {
    .tv-screenM { display: flex; }
    .tv-screen { display: none; }
  }
  @media only screen and (min-width: 1025px) {
    .tv-screen { display: flex; }
    .tv-screenM { display: none; }
  }
</style>
