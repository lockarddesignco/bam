---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Page Not Found | BAM" description="The page you're looking for could not be found.">
  <section class="py-24 px-6 min-h-[50vh] flex items-center justify-center">
    <div class="text-center">
      <h1 class="text-4xl font-black text-primary mb-4">404</h1>
      <p class="text-slate mb-8">Page not found.</p>
      <a href="/" class="inline-block bg-primary text-white px-6 py-3 font-bold uppercase text-sm tracking-wider hover:bg-primary/90 transition-colors">
        Back to Home
      </a>
    </div>
  </section>
</BaseLayout>
