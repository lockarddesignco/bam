  @media (min-width: 768px) {
    #about-nav .about-nav-btn.active .nav-chevron {
      display: block;
    }
  }

  /* Panel animation */
  .about-panel {
    animation: fadeSlideIn 0.4s ease-out;
  }
  @keyframes fadeSlideIn {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>

<script is:inline>
  (function initAboutNav() {
    var navButtons = document.querySelectorAll('.about-nav-btn');
    var panels = document.querySelectorAll('.about-panel');

    function switchTab(tabId) {
      for (var i = 0; i < panels.length; i++) {
        panels[i].style.display = 'none';
      }
      var target = document.getElementById('panel-' + tabId);
      if (target) {
        target.style.display = 'block';
      }

      var sidebarBtns = document.querySelectorAll('#about-nav .about-nav-btn');
      for (var j = 0; j < sidebarBtns.length; j++) {
        if (sidebarBtns[j].getAttribute('data-tab') === tabId) {
          sidebarBtns[j].classList.add('active');
        } else {
          sidebarBtns[j].classList.remove('active');
        }
      }

      history.replaceState(null, '', '#' + tabId);
    }

    for (var k = 0; k < navButtons.length; k++) {
      navButtons[k].addEventListener('click', function() {
        var tab = this.getAttribute('data-tab');
        if (tab) switchTab(tab);
      });
    }

    var hash = window.location.hash.replace('#', '');
    var validTabs = ['hub','company','method','compliance','safety','coverage','leadership','documentation','careers'];
    if (hash && validTabs.indexOf(hash) !== -1) {
      switchTab(hash);
    } else {
      switchTab('hub');
    }
  })();
</script>

</BaseLayout>
