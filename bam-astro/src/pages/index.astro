  <section class="relative py-24 md:py-32 bg-ice overflow-hidden">
    <div class="absolute inset-0 opacity-[0.03] site-grid-light"></div>
    <div class="relative z-10 max-w-5xl mx-auto px-6 md:px-12 lg:px-16">
