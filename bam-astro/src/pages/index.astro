          Human-Led Service. Compliance-Driven Process.
        </h2>
      </div>

      <div id="method-path-container" class="relative">
        <!-- Mobile vertical connecting line — positioned by JS between first and last node -->
        <div id="method-mobile-line" class="lg:hidden absolute left-1/2 -translate-x-1/2 w-px pointer-events-none z-[5]" style="top: 0; bottom: 0;">
          <div class="absolute inset-0 border-l-2 border-dashed border-light-grey/40"></div>
          <div id="method-mobile-line-lit" class="absolute top-0 left-0 w-0.5 bg-mint rounded-full" style="height: 0%; transition: height 0.8s cubic-bezier(0.16, 1, 0.3, 1);"></div>
        </div>

        <!-- SVG serpentine path (desktop) -->
        <svg id="method-svg" class="hidden lg:block absolute inset-0 w-full h-full pointer-events-none z-0" preserveAspectRatio="none">
          <path id="method-path-bg" class="fill-none stroke-light-grey/40" stroke-width="2" stroke-dasharray="8 6" />
          <path id="method-path-lit" class="fill-none stroke-mint" stroke-width="3" stroke-linecap="round" />
        </svg>

        <!-- Step 1 — Left -->
        <div class="method-step relative z-10 flex flex-col lg:flex-row items-center gap-6 lg:gap-14 mb-16 lg:mb-28" data-step="0">
          <div class="method-step-image relative w-full lg:w-[48%] h-[240px] md:h-[280px] rounded-xl overflow-hidden shadow-[0_4px_24px_rgba(0,0,0,0.04)] border border-light-grey/50 group">
            <img src="/images/method/diagnose.png" alt="Technician inspecting HVAC unit interior" class="w-full h-full object-cover grayscale transition-transform duration-700 group-hover:scale-105" loading="lazy" />
            <div class="absolute inset-0 bg-primary mix-blend-multiply opacity-40 group-hover:opacity-25 transition-opacity duration-500"></div>
          </div>
          <div class="method-node mx-auto lg:hidden flex-shrink-0 w-14 h-14 rounded-full border-2 border-light-grey bg-ice flex items-center justify-center text-slate font-black text-lg transition-all duration-700">01</div>
          <div class="flex-1 flex items-start gap-5 text-center lg:text-left">
            <div class="hidden lg:flex method-node flex-shrink-0 w-14 h-14 rounded-full border-2 border-light-grey bg-ice items-center justify-center text-slate font-black text-lg transition-all duration-700">01</div>
            <div>
              <h3 class="text-primary text-2xl md:text-3xl font-bold mb-3 tracking-tight">Diagnose</h3>
              <p class="text-slate text-base leading-relaxed max-w-md">Technicians perform airflow testing, coil inspection, static pressure checks, and IAQ assessments.</p>
            </div>
          </div>
        </div>

        <!-- Step 2 — Right -->
        <div class="method-step relative z-10 flex flex-col lg:flex-row-reverse items-center gap-6 lg:gap-14 mb-16 lg:mb-28" data-step="1">
          <div class="method-step-image relative w-full lg:w-[48%] h-[240px] md:h-[280px] rounded-xl overflow-hidden shadow-[0_4px_24px_rgba(0,0,0,0.04)] border border-light-grey/50 group">
            <img src="/images/method/document.png" alt="Technician documenting coil before/after with checklist" class="w-full h-full object-cover grayscale transition-transform duration-700 group-hover:scale-105" loading="lazy" />
            <div class="absolute inset-0 bg-primary mix-blend-multiply opacity-40 group-hover:opacity-25 transition-opacity duration-500"></div>
          </div>
          <div class="method-node mx-auto lg:hidden flex-shrink-0 w-14 h-14 rounded-full border-2 border-light-grey bg-ice flex items-center justify-center text-slate font-black text-lg transition-all duration-700">02</div>
          <div class="flex-1 flex items-start gap-5 lg:justify-end text-center lg:text-left">
            <div class="lg:text-right">
              <h3 class="text-primary text-2xl md:text-3xl font-bold mb-3 tracking-tight lg:text-right">Document</h3>
              <p class="text-slate text-base leading-relaxed max-w-md lg:text-right">We provide detailed before-photos, findings, compliance notes, and transparent reporting.</p>
            </div>
            <div class="hidden lg:flex method-node flex-shrink-0 w-14 h-14 rounded-full border-2 border-light-grey bg-ice items-center justify-center text-slate font-black text-lg transition-all duration-700">02</div>
          </div>
        </div>

        <!-- Step 3 — Left -->
        <div class="method-step relative z-10 flex flex-col lg:flex-row items-center gap-6 lg:gap-14 mb-16 lg:mb-28" data-step="2">
          <div class="method-step-image relative w-full lg:w-[48%] h-[240px] md:h-[280px] rounded-xl overflow-hidden shadow-[0_4px_24px_rgba(0,0,0,0.04)] border border-light-grey/50 group">
