            <div class="absolute inset-0 bg-primary mix-blend-multiply opacity-40 group-hover:opacity-25 transition-opacity duration-500"></div>
          </div>
          <div class="method-node mx-auto lg:hidden flex-shrink-0 w-14 h-14 rounded-full border-2 border-light-grey bg-ice flex items-center justify-center text-slate font-black text-lg transition-all duration-700">03</div>
