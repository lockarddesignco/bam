            <div class="hidden lg:flex method-node flex-shrink-0 w-14 h-14 rounded-full border-2 border-light-grey bg-ice items-center justify-center text-slate font-black text-lg transition-all duration-700">03</div>
            <div>
              <h3 class="text-primary text-2xl md:text-3xl font-bold mb-3 tracking-tight">Restore</h3>
              <p class="text-slate text-base leading-relaxed max-w-md">Certified technicians restore coils, cooling towers, ducts, and mechanical components.</p>
            </div>
          </div>
        </div>

        <!-- Step 4 — Right -->
        <div class="method-step relative z-10 flex flex-col lg:flex-row-reverse items-center gap-6 lg:gap-14" data-step="3">
          <div class="method-step-image relative w-full lg:w-[48%] h-[240px] md:h-[280px] rounded-xl overflow-hidden shadow-[0_4px_24px_rgba(0,0,0,0.04)] border border-light-grey/50 group">
