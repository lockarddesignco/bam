<script>
  function initGridPulse(canvasId: string, gridSize: number, maxDots: number, spawnMs: number) {
    const canvas = document.getElementById(canvasId) as HTMLCanvasElement;
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    const CONNECTION_DISTANCE = gridSize * 5;

    interface Dot {
      x: number; y: number; life: number; maxLife: number; radius: number; alpha: number;
    }

    const dots: Dot[] = [];
    let lastSpawn = 0;

    function resize() {
      const rect = canvas.parentElement!.getBoundingClientRect();
      canvas.width = rect.width;
      canvas.height = rect.height;
    }

    resize();
    window.addEventListener('resize', resize);

    function spawnDot(now: number) {
      if (dots.length >= maxDots || now - lastSpawn < spawnMs) return;
      lastSpawn = now;
      const cols = Math.floor(canvas.width / gridSize);
      const rows = Math.floor(canvas.height / gridSize);
      const x = (Math.floor(Math.random() * cols) + 1) * gridSize;
      const y = (Math.floor(Math.random() * rows) + 1) * gridSize;
      dots.push({ x, y, life: 0, maxLife: 1200 + Math.random() * 1600, radius: 3 + Math.random() * 4, alpha: 0 });
    }

    function draw(now: number) {
      ctx!.clearRect(0, 0, canvas.width, canvas.height);
      spawnDot(now);

      for (let i = dots.length - 1; i >= 0; i--) {
        const d = dots[i];
        d.life += 16;
        const progress = d.life / d.maxLife;
        if (progress >= 1) { dots.splice(i, 1); continue; }

        const alpha = progress < 0.3 ? progress / 0.3 : 1 - ((progress - 0.3) / 0.7);
        d.alpha = alpha;

        const grad = ctx!.createRadialGradient(d.x, d.y, 0, d.x, d.y, d.radius * 6);
        grad.addColorStop(0, `rgba(167, 215, 197, ${alpha * 0.35})`);
        grad.addColorStop(1, 'rgba(167, 215, 197, 0)');
        ctx!.fillStyle = grad;
        ctx!.beginPath();
        ctx!.arc(d.x, d.y, d.radius * 6, 0, Math.PI * 2);
        ctx!.fill();

        ctx!.fillStyle = `rgba(167, 215, 197, ${alpha * 0.8})`;
        ctx!.beginPath();
        ctx!.arc(d.x, d.y, d.radius, 0, Math.PI * 2);
        ctx!.fill();
      }

      for (let i = 0; i < dots.length; i++) {
        for (let j = i + 1; j < dots.length; j++) {
          const a = dots[i], b = dots[j];
          const dist = Math.sqrt((a.x - b.x) ** 2 + (a.y - b.y) ** 2);
          if (dist < CONNECTION_DISTANCE) {
            ctx!.strokeStyle = `rgba(167, 215, 197, ${Math.min(a.alpha, b.alpha) * (1 - dist / CONNECTION_DISTANCE) * 0.18})`;
            ctx!.lineWidth = 1;
            ctx!.beginPath();
            ctx!.moveTo(a.x, a.y);
            ctx!.lineTo(b.x, b.y);
            ctx!.stroke();
          }
        }
      }
      requestAnimationFrame(draw);
    }
    requestAnimationFrame(draw);
  }

  initGridPulse('grid-pulse-canvas', 48, 6, 800);
  initGridPulse('why-bam-pulse-canvas', 48, 4, 1000);

  // One continuous wave field rendered into every service card.
  // An offscreen canvas covers the full grid; each card canvas copies its
  // region from the offscreen buffer, so the wave is one seamless surface
  // visible through each card like windows in a wall.
  (function initCardWaves() {
    const grid = document.getElementById('services-grid');
    if (!grid) return;
    const cardCanvases = grid.querySelectorAll<HTMLCanvasElement>('.wave-card-bg');
    if (!cardCanvases.length) return;

    const STEP = 5;
    const offscreen = document.createElement('canvas');
    const offCtx = offscreen.getContext('2d')!;

    interface CardInfo {
      canvas: HTMLCanvasElement;
      ctx: CanvasRenderingContext2D;
      ox: number; oy: number; w: number; h: number;
    }

    const cards: CardInfo[] = [];
    cardCanvases.forEach(c => {
      const ctx = c.getContext('2d');
      if (ctx) cards.push({ canvas: c, ctx, ox: 0, oy: 0, w: 0, h: 0 });
    });

    function measure() {
      const gr = grid!.getBoundingClientRect();
      offscreen.width = Math.ceil(gr.width);
      offscreen.height = Math.ceil(gr.height);
      for (const card of cards) {
        const cr = card.canvas.parentElement!.getBoundingClientRect();
        card.ox = Math.round(cr.left - gr.left);
        card.oy = Math.round(cr.top - gr.top);
        card.w = Math.round(cr.width);
        card.h = Math.round(cr.height);
        card.canvas.width = card.w;
        card.canvas.height = card.h;
      }
    }

    measure();
    window.addEventListener('resize', measure);

    function waveHeight(gx: number, gy: number, t: number): number {
      const s = 0.007;
      const v1 = Math.sin(gx * s + gy * s * 0.5 + t * 0.0018);
      const v2 = Math.sin(gx * s * 0.6 - gy * s * 0.9 + t * 0.0013 + 1.3);
      const v3 = Math.sin(gx * s * 1.2 + gy * s * 0.3 - t * 0.0015 + 2.7);
      const v4 = Math.sin((gx + gy) * s * 0.4 + t * 0.001 + 4.1);
      return (v1 + v2 * 0.8 + v3 * 0.5 + v4 * 0.4) / 2.7 * 0.5 + 0.5;
    }

    function draw(t: number) {
      const gw = offscreen.width;
      const gh = offscreen.height;
      offCtx.clearRect(0, 0, gw, gh);

      for (let y = 0; y < gh; y += STEP) {
        for (let x = 0; x < gw; x += STEP) {
          const val = waveHeight(x, y, t);
          const r = Math.round(30 + (160 - 30) * val);
          const g = Math.round(80 + (215 - 80) * val);
          const b = Math.round(65 + (190 - 65) * val);
          const alpha = 0.18 + val * 0.22;
          offCtx.fillStyle = `rgba(${r},${g},${b},${alpha})`;
          offCtx.fillRect(x, y, STEP, STEP);
        }
      }

      for (const card of cards) {
        card.ctx.clearRect(0, 0, card.w, card.h);
        card.ctx.drawImage(
          offscreen,
          card.ox, card.oy, card.w, card.h,
          0, 0, card.w, card.h
        );
      }

      requestAnimationFrame(draw);
    }

    requestAnimationFrame(draw);
  })();

  // BAM Method — serpentine path + scroll activation
  (function initMethodPath() {
    const container = document.getElementById('method-path-container');
    const svg = document.getElementById('method-svg') as SVGSVGElement | null;
    const pathBg = document.getElementById('method-path-bg') as SVGPathElement | null;
    const pathLit = document.getElementById('method-path-lit') as SVGPathElement | null;
    const mobileLine = document.getElementById('method-mobile-line-lit') as HTMLElement | null;
    const steps = document.querySelectorAll<HTMLElement>('.method-step');
    const allNodes = document.querySelectorAll<HTMLElement>('.method-node');
    if (!container || steps.length < 2) return;

    const mobileLineEl = document.getElementById('method-mobile-line') as HTMLElement | null;
    const isDesktop = () => window.innerWidth >= 1024;

    function positionMobileLine() {
      if (isDesktop() || !mobileLineEl || !container) return;
      const firstNode = getVisibleNode(steps[0]);
      const lastNode = getVisibleNode(steps[steps.length - 1]);
      if (!firstNode || !lastNode) return;
      const cr = container.getBoundingClientRect();
      const fn = firstNode.getBoundingClientRect();
      const ln = lastNode.getBoundingClientRect();
      const top = fn.top - cr.top + fn.height / 2;
      const bottom = ln.top - cr.top + ln.height / 2;
      mobileLineEl.style.top = `${top}px`;
      mobileLineEl.style.height = `${bottom - top}px`;
      mobileLineEl.style.bottom = 'auto';
    }

    function getVisibleNode(stepEl: HTMLElement): Element | null {
      const nodes = stepEl.querySelectorAll('.method-node');
      for (const n of nodes) {
        if ((n as HTMLElement).offsetParent !== null) return n;
      }
      return nodes[0];
    }

    function getNodeCenter(stepEl: HTMLElement): { x: number; y: number } {
      const node = getVisibleNode(stepEl);
      if (!node) return { x: 0, y: 0 };
      const cr = container!.getBoundingClientRect();
      const nr = node.getBoundingClientRect();
      return {
        x: nr.left - cr.left + nr.width / 2,
        y: nr.top - cr.top + nr.height / 2,
      };
    }

    function buildPath() {
      if (!isDesktop() || !svg || !pathBg || !pathLit) return;
      const cr = container!.getBoundingClientRect();
      svg.setAttribute('viewBox', `0 0 ${cr.width} ${cr.height}`);
      svg.style.width = cr.width + 'px';
      svg.style.height = cr.height + 'px';

      const points = Array.from(steps).map(s => getNodeCenter(s));
      if (points.some(p => p.x === 0 && p.y === 0)) return;

      let d = `M ${points[0].x} ${points[0].y}`;
      for (let i = 0; i < points.length - 1; i++) {
        const curr = points[i];
        const next = points[i + 1];
        const midY = (curr.y + next.y) / 2;
        d += ` C ${curr.x} ${midY}, ${next.x} ${midY}, ${next.x} ${next.y}`;
      }

      pathBg.setAttribute('d', d);
      pathLit.setAttribute('d', d);

      const totalLen = pathLit.getTotalLength();
      pathLit.style.strokeDasharray = `${totalLen}`;
      pathLit.style.strokeDashoffset = `${totalLen}`;
    }

    let resizeTimer: number;
    function onResize() {
      clearTimeout(resizeTimer);
      resizeTimer = window.setTimeout(() => { buildPath(); positionMobileLine(); }, 150) as unknown as number;
    }

    setTimeout(() => { buildPath(); positionMobileLine(); }, 200);
    window.addEventListener('resize', onResize);

    const active = new Set<number>();

    function updateProgress() {
      const fraction = active.size === 0 ? 0 : (Math.max(...Array.from(active)) + 1) / steps.length;

      if (isDesktop() && pathLit) {
        const totalLen = pathLit.getTotalLength();
        if (totalLen > 0) {
          pathLit.style.transition = 'stroke-dashoffset 0.8s cubic-bezier(0.16, 1, 0.3, 1)';
          pathLit.style.strokeDashoffset = `${totalLen * (1 - fraction)}`;
        }
      }

      if (!isDesktop() && mobileLine) {
        mobileLine.style.height = `${Math.min(fraction * 100, 100)}%`;
      }
    }

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach(entry => {
          const idx = Number((entry.target as HTMLElement).dataset.step);
          const stepNodes = entry.target.querySelectorAll('.method-node');
          if (entry.isIntersecting) {
            active.add(idx);
            entry.target.classList.add('method-active');
            stepNodes.forEach(n => n.classList.add('method-node-lit'));
          } else {
            active.delete(idx);
            entry.target.classList.remove('method-active');
            stepNodes.forEach(n => n.classList.remove('method-node-lit'));
          }
        });
        updateProgress();
      },
      { threshold: 0.2, rootMargin: '0px 0px -30% 0px' }
    );

    steps.forEach(step => observer.observe(step));
  })();

  // Blog carousel — infinite translate loop with drag & buttons
  (function initBlogCarousel() {
    const wrapper = document.getElementById('blog-carousel-wrapper') as HTMLElement | null;
    const track = document.getElementById('blog-carousel') as HTMLElement | null;
    const prevBtn = document.getElementById('blog-prev') as HTMLElement | null;
    const nextBtn = document.getElementById('blog-next') as HTMLElement | null;
    const progressBar = document.getElementById('blog-progress-bar') as HTMLElement | null;
    if (!wrapper || !track) return;

    const cards = track.querySelectorAll<HTMLElement>('.blog-card');
    const totalCards = cards.length;
    if (!totalCards) return;

    const CARD_GAP = 24;
    const AUTO_SPEED = 0.6;
    const ORIGINAL_COUNT = totalCards / 3;

    let offset = 0;
    let autoScrollPaused = false;
    let pauseTimeout: number | undefined;
    let isDragging = false;
    let startX = 0;
    let dragOffset = 0;
    let hasDragged = false;
    let smoothTarget: number | null = null;
    let smoothStart = 0;
    let smoothStartTime = 0;
    const SMOOTH_DURATION = 400;

    function getOneSetWidth() {
      const card = cards[0];
      if (!card) return 0;
      return ORIGINAL_COUNT * (card.offsetWidth + CARD_GAP);
    }

    function wrapOffset() {
      const oneSet = getOneSetWidth();
      if (oneSet <= 0) return;
      while (offset >= oneSet * 2) offset -= oneSet;
      while (offset < oneSet) offset += oneSet;
    }

    function applyTransform() {
      track!.style.transform = `translate3d(${-offset}px, 0, 0)`;
    }

    function updateProgress() {
      if (!progressBar) return;
      const oneSet = getOneSetWidth();
      if (oneSet <= 0) return;
      const normalised = ((offset % oneSet) / oneSet) * 100;
      progressBar.style.width = `${Math.max(8, Math.min(100, normalised))}%`;
    }

    function updateCardPerspective() {
      const wrapperRect = wrapper!.getBoundingClientRect();
      const center = wrapperRect.left + wrapperRect.width / 2;
      const halfW = wrapperRect.width / 2;

      cards.forEach((card) => {
        const cardRect = card.getBoundingClientRect();
        const cardCenter = cardRect.left + cardRect.width / 2;

        if (cardRect.right < wrapperRect.left - 400 || cardRect.left > wrapperRect.right + 400) {
          return;
        }

        const dist = (cardCenter - center) / halfW;
        const c = Math.max(-1, Math.min(1, dist));

        const rotateY = c * -3;
        const scale = 1 - Math.abs(c) * 0.05;
        const alpha = 1 - Math.abs(c) * 0.25;

        card.style.transform = `perspective(1200px) rotateY(${rotateY}deg) scale(${scale})`;
        card.style.opacity = `${alpha}`;
      });
    }

    // Start at the middle set so we can scroll both directions
    offset = getOneSetWidth();
    applyTransform();

    function frame() {
      if (smoothTarget !== null) {
        const elapsed = performance.now() - smoothStartTime;
        const t = Math.min(elapsed / SMOOTH_DURATION, 1);
        const ease = t < 0.5 ? 2 * t * t : -1 + (4 - 2 * t) * t;
        offset = smoothStart + (smoothTarget - smoothStart) * ease;
        if (t >= 1) smoothTarget = null;
      } else if (!autoScrollPaused && !isDragging) {
        offset += AUTO_SPEED;
      }

      wrapOffset();
      applyTransform();
      updateProgress();
      updateCardPerspective();
      requestAnimationFrame(frame);
    }
    requestAnimationFrame(frame);

    function pauseAuto(ms: number) {
      autoScrollPaused = true;
      clearTimeout(pauseTimeout);
      pauseTimeout = window.setTimeout(() => { autoScrollPaused = false; }, ms);
    }

    function smoothScrollBy(px: number) {
      smoothTarget = offset + px;
      smoothStart = offset;
      smoothStartTime = performance.now();
      pauseAuto(4000);
    }

    function getCardWidth() {
      return cards[0].offsetWidth + CARD_GAP;
    }

    prevBtn?.addEventListener('click', () => smoothScrollBy(-getCardWidth()));
    nextBtn?.addEventListener('click', () => smoothScrollBy(getCardWidth()));

    const DRAG_THRESHOLD = 10;

    // Mouse drag — events on wrapper so overflow:hidden doesn't clip interaction
    wrapper.addEventListener('mousedown', (e) => {
      isDragging = true;
      hasDragged = false;
      smoothTarget = null;
      startX = e.pageX;
      dragOffset = offset;
    });
    window.addEventListener('mousemove', (e) => {
      if (!isDragging) return;
      const dx = e.pageX - startX;
      if (!hasDragged && Math.abs(dx) > DRAG_THRESHOLD) {
        hasDragged = true;
        wrapper!.classList.add('is-dragging');
      }
      if (hasDragged) offset = dragOffset - dx;
    });
    window.addEventListener('mouseup', () => {
      if (isDragging) {
        isDragging = false;
        wrapper!.classList.remove('is-dragging');
        if (hasDragged) pauseAuto(4000);
      }
    });

    // Touch drag
    wrapper.addEventListener('touchstart', (e) => {
      isDragging = true;
      hasDragged = false;
      smoothTarget = null;
      startX = e.touches[0].pageX;
      dragOffset = offset;
    }, { passive: true });
    wrapper.addEventListener('touchmove', (e) => {
      if (!isDragging) return;
      const dx = e.touches[0].pageX - startX;
      if (!hasDragged && Math.abs(dx) > DRAG_THRESHOLD) {
        hasDragged = true;
        wrapper!.classList.add('is-dragging');
      }
      if (hasDragged) offset = dragOffset - dx;
    }, { passive: true });
    wrapper.addEventListener('touchend', () => {
      isDragging = false;
      wrapper!.classList.remove('is-dragging');
      if (hasDragged) pauseAuto(4000);
    });

    // Pause on hover
    wrapper.addEventListener('mouseenter', () => { autoScrollPaused = true; });
    wrapper.addEventListener('mouseleave', () => {
      if (!autoScrollPaused) return;
      if (!isDragging) autoScrollPaused = false;
    });

    // Block link clicks after drag
    cards.forEach(card => {
      card.addEventListener('click', (e) => {
        if (hasDragged) {
          e.preventDefault();
          e.stopPropagation();
          hasDragged = false;
        }
      });
    });
  })();

</script>
