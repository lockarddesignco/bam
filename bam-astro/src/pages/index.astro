---
import BaseLayout from '../layouts/BaseLayout.astro';
import YouTubeEmbed from '../components/YouTubeEmbed.astro';
import { siteConfig } from '../config/site.config';
import { getCollection } from 'astro:content';

const coreServices = siteConfig.services.filter(s => s.category === 'core');
const specialtyServices = siteConfig.services.filter(s => s.category === 'specialty');
const allDisplayServices = [...coreServices, ...specialtyServices.filter(s => s.id === 'dampers')];

const allPosts = (await getCollection('blog'))
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const serviceIconMap: Record<string, string> = {
  'cooling-tower': `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"/></svg>`,
  'chiller': `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12h20"/><path d="M12 2v20"/><path d="m4.93 4.93 14.14 14.14"/><path d="m19.07 4.93-14.14 14.14"/></svg>`,
  'ahu': `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 4v10.54a4 4 0 1 1-4 0V4a2 2 0 0 1 4 0Z"/></svg>`,
  'ducts': `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17.7 7.7a2.5 2.5 0 1 1 1.8 4.3H2"/><path d="M9.6 4.6A2 2 0 1 1 11 8H2"/><path d="M12.6 19.4A2 2 0 1 0 14 16H2"/></svg>`,
  'iaq': `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>`,
  'mold': `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>`,
  'pm': `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/></svg>`,
  'hepa': `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m12.83 2.18a2 2 0 0 0-1.66 0L2.6 6.08a1 1 0 0 0 0 1.83l8.58 3.91a2 2 0 0 0 1.66 0l8.58-3.9a1 1 0 0 0 0-1.83Z"/><path d="m6.08 9.5-3.5 1.6a1 1 0 0 0 0 1.81l8.6 3.91a2 2 0 0 0 1.65 0l8.58-3.9a1 1 0 0 0 0-1.83l-3.5-1.59"/><path d="m6.08 14.5-3.5 1.6a1 1 0 0 0 0 1.81l8.6 3.91a2 2 0 0 0 1.65 0l8.58-3.9a1 1 0 0 0 0-1.83l-3.5-1.59"/></svg>`,
  'dampers': `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"/></svg>`,
  'epoxy': `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m12.83 2.18a2 2 0 0 0-1.66 0L2.6 6.08a1 1 0 0 0 0 1.83l8.58 3.91a2 2 0 0 0 1.66 0l8.58-3.9a1 1 0 0 0 0-1.83Z"/><path d="m6.08 9.5-3.5 1.6a1 1 0 0 0 0 1.81l8.6 3.91a2 2 0 0 0 1.65 0l8.58-3.9a1 1 0 0 0 0-1.83l-3.5-1.59"/><path d="m6.08 14.5-3.5 1.6a1 1 0 0 0 0 1.81l8.6 3.91a2 2 0 0 0 1.65 0l8.58-3.9a1 1 0 0 0 0-1.83l-3.5-1.59"/></svg>`,
  'tubes': `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m12 14 4-4"/><path d="M3.34 19a10 10 0 1 1 17.32 0"/></svg>`,
  'basin': `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 6c.6.5 1.2 1 2.5 1C7 7 7 5 9.5 5c2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/><path d="M2 12c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/><path d="M2 18c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/></svg>`,
};

const industryIconMap: Record<string, string> = {
  'healthcare': `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4.8 2.3A.3.3 0 1 0 5 2H4a2 2 0 0 0-2 2v5a6 6 0 0 0 6 6v0a6 6 0 0 0 6-6V4a2 2 0 0 0-2-2h-1a.2.2 0 1 0 .3.3"/><path d="M8 15v1a6 6 0 0 0 6 6v0a6 6 0 0 0 6-6v-4"/><path d="M22 10 A2 2 0 0 1 20 12 A2 2 0 0 1 18 10 A2 2 0 0 1 22 10z"/></svg>`,
  'k12': `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>`,
  'higher-ed': `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="2" width="16" height="20" rx="2"/><path d="M9 22v-4h6v4"/><path d="M8 6h.01"/><path d="M16 6h.01"/><path d="M12 6h.01"/><path d="M12 10h.01"/><path d="M12 14h.01"/><path d="M16 10h.01"/><path d="M16 14h.01"/><path d="M8 10h.01"/><path d="M8 14h.01"/></svg>`,
  'government': `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="3" x2="21" y1="22" y2="22"/><line x1="6" x2="6" y1="18" y2="11"/><line x1="10" x2="10" y1="18" y2="11"/><line x1="14" x2="14" y1="18" y2="11"/><line x1="18" x2="18" y1="18" y2="11"/><polygon points="12 2 20 7 4 7"/></svg>`,
  'industrial': `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 20a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V8l-7 5V8l-7 5V4a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2Z"/><path d="M17 18h1"/><path d="M12 18h1"/><path d="M7 18h1"/></svg>`,
  'commercial': `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="16" height="20" x="4" y="2" rx="2" ry="2"/><path d="M9 22v-4h6v4"/><path d="M8 6h.01"/><path d="M16 6h.01"/><path d="M12 6h.01"/><path d="M12 10h.01"/><path d="M12 14h.01"/><path d="M16 10h.01"/><path d="M16 14h.01"/><path d="M8 10h.01"/><path d="M8 14h.01"/></svg>`,
  'retail': `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>`,
  'senior-care': `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/><path d="M12 5 9.04 7.96a2.17 2.17 0 0 0 0 3.08v0c.82.82 2.13.85 3 .07l2.07-1.9a2.82 2.82 0 0 1 3.79 0l2.96 2.66"/><path d="m18 15-2-2"/><path d="m15 18-2-2"/></svg>`,
  'cold-storage': `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m7.5 4.27 9 5.15"/><path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"/><path d="m3.3 7 8.7 5 8.7-5"/><path d="M12 22V12"/></svg>`,
  'education': `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>`,
  'food-processing': `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 11h.01"/><path d="M11 15h.01"/><path d="M16 16h.01"/><path d="m2 16 20 6-6-20A20 20 0 0 0 2 16"/><path d="M5.71 17.11a17.04 17.04 0 0 1 11.4-11.4"/></svg>`,
  'data-centers': `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="8" x="2" y="2" rx="2" ry="2"/><rect width="20" height="8" x="2" y="14" rx="2" ry="2"/><line x1="6" x2="6.01" y1="6" y2="6"/><line x1="6" x2="6.01" y1="18" y2="18"/></svg>`,
  'labs': `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10 2v7.527a2 2 0 0 1-.211.896L4.72 20.55a1 1 0 0 0 .9 1.45h12.76a1 1 0 0 0 .9-1.45l-5.069-10.127A2 2 0 0 1 14 9.527V2"/><path d="M8.5 2h7"/><path d="M7 16h10"/></svg>`,
};

const homeFaqs = [
  { q: 'Do you provide commercial HVAC restoration for residential properties?', a: 'No. BAM strictly serves mission-critical institutions, including hospitals, K-12 school districts, universities, federal agencies, and large manufacturing plants. Our technicians specialize exclusively in high-stakes commercial environments where catastrophic mechanical failure is not an option. We occupy a space above typical duct cleaners and do not perform residential HVAC repairs or standard home duct cleaning.' },
  { q: 'How do your HVAC restoration services support Joint Commission compliance for healthcare facilities?', a: 'Our HVAC restoration directly aligns with Joint Commission survey requirements by ensuring sterile environments, proper system pressurization, and the complete elimination of microbial growth. We provide rigorous documentation and post-remediation verification for every project. Our "do no harm" philosophy guarantees that our OSHA-30 certified technicians treat your medical mechanical rooms with the absolute highest level of precision and care.' },
  { q: "Can commercial coil and chiller refurbishment actually reduce our facility's HVAC energy spend?", a: "Yes. Deep cleaning and structural refurbishment of air handling units, coils, and chillers restores maximum airflow and thermal transfer. This drastically reduces the mechanical load, extending the equipment's lifespan and clawing back significant portions of your HVAC energy budget. Every recommendation BAM makes is tied directly to measurable energy spend reduction and protecting your long-term mechanical assets." },
  { q: 'Are your technicians cleared to work in high-security federal and government buildings?', a: 'Yes. BAM operates with federal-level discretion and discipline, having successfully executed months of complex restoration work inside highly secure government environments. We bring this exact same standard of zero shortcuts, stringent documentation, and absolute precision to every hospital, school, and manufacturing plant we service.' },
  { q: 'How does commercial cooling tower restoration impact manufacturing production downtime?', a: 'Our restoration process is engineered to minimize or eliminate operational downtime, actively preventing the catastrophic daily losses associated with sudden process cooling failures. We use specialized epoxy coatings, basin restorations, and precise project management to rebuild your infrastructure efficiently. BAM acts as a long-term maintenance partner, replacing unexpected mechanical emergencies with predictable, budgeted forecasting.' },
  { q: 'What certifications do BAM technicians hold for commercial duct cleaning and indoor air quality?', a: 'BAM is a NADCA-certified firm, and our technicians hold Universal EPA and OSHA-30 certifications. We execute all indoor air quality testing, mold remediation, and duct cleaning services in strict alignment with ASHRAE standards and LEED Indoor Environmental Quality guidelines. Built by technicians, our leadership prioritizes deep technical competence and ethical long-term stewardship over short-sighted financial gain.' },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: homeFaqs.map((faq) => ({
    '@type': 'Question',
    name: faq.q,
    acceptedAnswer: { '@type': 'Answer', text: faq.a },
  })),
};
---
<BaseLayout
  title="BAM | Building & Air Maintenance — Commercial HVAC Restoration"
  description="Specialized HVAC restoration, indoor air quality, and compliance-focused mechanical services for commercial and institutional facilities in PA, NJ, MD, DE, and Southern NY."
>

  <!-- ═══════════════════════════════════════════════════════════════
       HERO SECTION
       ═══════════════════════════════════════════════════════════════ -->
  <section class="relative w-full py-20 md:py-0 md:h-[90vh] md:min-h-[760px] flex flex-col items-center justify-center font-sans overflow-hidden bg-dark">
    <div class="absolute inset-0 z-0">
      <img
        src="https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?auto=format&fit=crop&w=2000&q=80"
        alt="Modern Commercial Facility Facade"
        class="w-full h-full object-cover opacity-30"
        loading="eager"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-dark/80 via-dark/50 to-dark"></div>
      <div class="absolute inset-0 opacity-[0.04] site-grid-dark"></div>
      <canvas id="grid-pulse-canvas" class="absolute inset-0 w-full h-full pointer-events-none"></canvas>
    </div>

    <div class="relative z-10 w-full max-w-4xl mx-auto px-6 flex flex-col items-center text-center">
      <div class="mb-4 md:mb-7 flex items-center gap-3 animate-fade-in-up opacity-0" style="animation-delay: 0ms;">
        <div class="w-2 h-2 rounded-full bg-mint animate-pulse"></div>
        <span class="text-white font-bold text-[10px] md:text-xs tracking-[0.3em] uppercase opacity-80">Institutional Grade Service</span>
      </div>

      <h1 class="text-[2rem] md:text-[3.5rem] lg:text-[4.5rem] font-black leading-[0.88] tracking-tighter text-white mb-6 md:mb-10 animate-fade-in-up opacity-0 uppercase drop-shadow-2xl" style="animation-delay: 100ms;">
        Extending the Life&nbsp;of <br class="hidden md:inline" />
        <span class="text-mint">Mission-Critical</span> <br/>
        Clean Air Systems.
      </h1>

      <p class="text-[14px] md:text-lg text-light-grey/90 max-w-2xl leading-relaxed font-light mb-8 md:mb-14 opacity-0 animate-fade-in-up" style="animation-delay: 200ms;">
        BAM is a premium mechanical partner specializing in cooling tower restoration, AHU & coil refurbishment, and commercial indoor air quality. We help healthcare, educational, and federal facilities prevent catastrophic downtime and regain control of their energy spend.
      </p>

      <div class="flex flex-col sm:flex-row items-center gap-4 sm:gap-4 animate-fade-in-up opacity-0 w-full justify-center" style="animation-delay: 300ms;">
        <a
          href="/contact/"
          class="relative group inline-flex items-center justify-center font-bold tracking-widest text-xs py-4 md:py-[18px] px-8 md:px-10 rounded-sm w-full sm:w-auto sm:min-w-[240px] shadow-2xl bg-primary text-white border border-primary transition-all duration-300 overflow-hidden"
        >
          <span class="relative z-10 flex items-center justify-center gap-3">
            REQUEST SITE VISIT
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </span>
          <span class="mask-btn-layer absolute inset-0 z-20 flex items-center justify-center gap-3 bg-white text-primary font-bold tracking-widest text-xs w-[101%]">
            REQUEST SITE VISIT
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </span>
        </a>
        <a
          href={`tel:${siteConfig.phoneRaw}`}
          class="hidden sm:flex items-center justify-center gap-3 px-10 py-[18px] bg-[#1A1F1E] border border-white/10 text-white font-bold text-xs tracking-widest uppercase hover:bg-[#252b2a] hover:border-white/20 transition-all rounded-sm min-w-[240px] shadow-xl backdrop-blur-sm"
        >
          Call BAM Now
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-mint"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        </a>
      </div>

      <a href="/tools/" class="inline-flex items-center gap-1.5 text-mint/80 hover:text-mint text-xs font-semibold tracking-wider uppercase no-underline transition-colors mt-5 animate-fade-in-up opacity-0" style="animation-delay: 400ms;">
        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="flex-shrink-0"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/></svg>
        Refurbishment ROI Calculator
      </a>
    </div>

  </section>

  <!-- ═══════════════════════════════════════════════════════════════
       SERVICES HUB PREVIEW BAR
       ═══════════════════════════════════════════════════════════════ -->
  <a href="/services/" class="block w-full bg-primary py-4 text-center no-underline group hover:bg-[#1e483b] transition-colors">
    <span class="text-white font-bold text-xs md:text-sm uppercase tracking-[0.25em]">
      [ Preview Services Hub ]
    </span>
  </a>

  <!-- ═══════════════════════════════════════════════════════════════
       ACCREDITATIONS SECTION
       ═══════════════════════════════════════════════════════════════ -->
  <section class="py-12 bg-ice border-y border-light-grey">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-8">
        <h3 class="text-sm font-bold tracking-[1.2px] text-slate uppercase">
          Accreditations & Certifications
        </h3>
      </div>

      <div
        class="relative w-full overflow-hidden"
        style="mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent); -webkit-mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);"
      >
        <div class="accreditations-track flex gap-8 w-max pr-10 py-4 items-center">
          {[...siteConfig.accreditations, ...siteConfig.accreditations, ...siteConfig.accreditations, ...siteConfig.accreditations, ...siteConfig.accreditations].map((accred, i) => (
            <div class="flex items-center justify-center flex-shrink-0 h-36 px-6 transition-all duration-300 transform origin-center cursor-default hover:scale-[1.05]">
              <img
                src={accred.logo}
                alt={accred.name}
                class="max-h-28 w-auto object-contain opacity-90 hover:opacity-100 transition-all duration-300"
                loading="lazy"
              />
              <span class="sr-only">{accred.name}</span>
            </div>
          ))}
        </div>
      </div>

      <div class="max-w-5xl mx-auto px-6 mt-6 text-center">
        <p class="text-slate text-lg md:text-[20px] font-semibold leading-relaxed">
          Fully compliant with Joint Commission, ASHRAE, and IEQ standards. NADCA Certified · Universal EPA · OSHA 30 · PA Co-Stars
        </p>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════
       SEE BAM IN ACTION — VIDEO
       ═══════════════════════════════════════════════════════════════ -->
  <section class="relative py-20 md:py-28 bg-dark overflow-hidden">
    <div class="absolute inset-0 opacity-[0.04] site-grid-dark"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[400px] rounded-full bg-mint/[0.06] blur-[150px] pointer-events-none"></div>

    <div class="relative z-10 max-w-4xl mx-auto px-6 md:px-12">
      <div class="text-center mb-10 md:mb-14">
