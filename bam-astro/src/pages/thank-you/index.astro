---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { siteConfig } from '../../config/site.config';
---

<BaseLayout
  title="Submission Received — Building & Air Maintenance"
  description="Thank you for contacting BAM. Our commercial team will review your submission and respond within one business day."
>

  <section class="relative w-full py-32 md:py-44 flex flex-col items-center justify-center bg-dark overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-dark/60 via-dark/80 to-dark"></div>
    <div class="absolute inset-0 opacity-[0.04] site-grid-dark"></div>

    <div class="relative z-10 max-w-3xl mx-auto px-6 text-center">
      <div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-mint/15 border border-mint/30 mb-8">
        <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-mint">
          <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" />
          <polyline points="22 4 12 14.01 9 11.01" />
        </svg>
      </div>

      <span class="inline-block mb-6 px-4 py-1.5 text-[10px] font-bold uppercase tracking-[0.3em] rounded-full border border-mint/30 text-mint bg-mint/10">
        Submission Received
      </span>

      <h1 class="text-4xl md:text-6xl font-black text-white tracking-tighter uppercase leading-[0.9] mb-8">
        Thank You
      </h1>

      <p class="text-lg md:text-xl text-light-grey max-w-2xl mx-auto leading-relaxed font-light mb-12">
        Your inquiry has been routed to our commercial team. We typically respond within one business day with next steps for your facility.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="/"
          class="inline-flex items-center gap-2 px-8 py-4 bg-mint text-primary font-bold text-sm uppercase tracking-widest rounded-sm transition-all hover:shadow-[0_10px_30px_-10px_rgba(167,215,197,0.5)] hover:-translate-y-0.5"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          Back to Home
        </a>
        <a
          href={`tel:${siteConfig.phoneRaw}`}
          class="inline-flex items-center gap-2 px-8 py-4 border border-mint/30 text-mint font-bold text-sm uppercase tracking-widest rounded-sm transition-all hover:bg-mint/10"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          Call {siteConfig.phone}
        </a>
      </div>
    </div>
  </section>

  <section class="relative py-16 md:py-20 bg-ice">
    <div class="absolute inset-0 opacity-[0.03] site-grid-light"></div>
    <div class="relative z-10 max-w-4xl mx-auto px-6 text-center">
      <h2 class="text-primary text-lg font-bold uppercase tracking-tight mb-6">What Happens Next</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-white border border-light-grey rounded-lg p-6">
          <div class="text-3xl font-black text-primary/20 mb-2">01</div>
          <h3 class="text-primary font-bold text-sm uppercase tracking-wide mb-2">Review</h3>
          <p class="text-slate text-sm leading-relaxed">Our team reviews your submission and assesses scope.</p>
        </div>
        <div class="bg-white border border-light-grey rounded-lg p-6">
          <div class="text-3xl font-black text-primary/20 mb-2">02</div>
          <h3 class="text-primary font-bold text-sm uppercase tracking-wide mb-2">Contact</h3>
          <p class="text-slate text-sm leading-relaxed">A commercial specialist reaches out within one business day.</p>
        </div>
        <div class="bg-white border border-light-grey rounded-lg p-6">
          <div class="text-3xl font-black text-primary/20 mb-2">03</div>
          <h3 class="text-primary font-bold text-sm uppercase tracking-wide mb-2">Coordinate</h3>
          <p class="text-slate text-sm leading-relaxed">We schedule an on-site assessment at your convenience.</p>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
