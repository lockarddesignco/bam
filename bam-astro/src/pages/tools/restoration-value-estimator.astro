<!-- ════════════════════ CALCULATOR LOGIC ════════════════════ -->
<script>
  const AGE_MULTIPLIERS: Record<string, number> = {
    '0-5': 0.02,
    '5-10': 0.05,
    '10-15': 0.10,
    '15-20+': 0.15,
  };

  const BASE_ENERGY_SPEND: Record<string, number> = {
    'under-50k': 35000,
    '50k-150k': 100000,
    '150k-500k': 325000,
    '500k-1m': 750000,
    '1m+': 1200000,
  };

  const ASSET_COUNTS: Record<string, number> = {
    '1': 1,
    '2-3': 2.5,
    '4-6': 5,
    '7+': 8,
  };

  const UNIT_REPLACEMENT_COST: Record<string, number> = {
    'cooling-tower': 125000,
    'chiller': 200000,
    'both': 325000,
  };

  function formatCurrency(n: number): string {
    return '$' + Math.round(n).toLocaleString('en-US');
  }

  function calculate() {
    const age = (document.getElementById('equipmentAge') as HTMLSelectElement).value;
    const spend = (document.getElementById('energySpend') as HTMLSelectElement).value;
    const asset = (document.getElementById('assetFocus') as HTMLSelectElement).value;
    const count = (document.getElementById('assetCount') as HTMLSelectElement).value;
    const facilityType = (document.getElementById('facilityType') as HTMLSelectElement).value;

    if (!age || !spend || !asset || !count || !facilityType) return;

    const issueCheckboxes = document.querySelectorAll<HTMLInputElement>('input[name="issues"]:checked');
    const numIssues = issueCheckboxes.length;

    const ageMultiplier = AGE_MULTIPLIERS[age] ?? 0;
    const baseSpend = BASE_ENERGY_SPEND[spend] ?? 0;
    const assetCount = ASSET_COUNTS[count] ?? 1;
    const unitCost = UNIT_REPLACEMENT_COST[asset] ?? 0;

    const issuePenalty = Math.min(numIssues * 0.015, 0.08);
    const lowSavings = baseSpend * ageMultiplier * 0.8;
    const highSavings = baseSpend * (ageMultiplier + issuePenalty) * 1.0;
    const avgSavings = (lowSavings + highSavings) / 2;

    const totalReplacement = assetCount * unitCost;
    const lowAvoidance = totalReplacement * 0.85;
    const highAvoidance = totalReplacement * 0.90;

    const estRestorationCost = totalReplacement * 0.15;
    const monthlyBenefit = avgSavings / 12;
    const paybackMonths = monthlyBenefit > 0 ? estRestorationCost / monthlyBenefit : Infinity;

    let paybackText: string;
    if (paybackMonths < 6) {
      paybackText = 'Immediate (<6 months)';
    } else if (paybackMonths > 24) {
      paybackText = '18–24+ Months';
    } else {
      paybackText = `${Math.floor(paybackMonths)}–${Math.ceil(paybackMonths)} Months`;
    }

    (document.getElementById('energy-savings') as HTMLElement).textContent =
      `${formatCurrency(lowSavings)} – ${formatCurrency(highSavings)} / year`;

    (document.getElementById('capital-avoidance') as HTMLElement).textContent =
      `${formatCurrency(lowAvoidance)} – ${formatCurrency(highAvoidance)}`;

    (document.getElementById('payback-period') as HTMLElement).textContent = paybackText;

    (document.getElementById('results-panel') as HTMLElement).classList.remove('hidden');
    (document.getElementById('results-placeholder') as HTMLElement).classList.add('hidden');

    const leadFacility = document.getElementById('lead-facility-type') as HTMLInputElement;
    const leadAsset = document.getElementById('lead-asset-focus') as HTMLInputElement;
    const leadSavings = document.getElementById('lead-estimated-savings') as HTMLInputElement;
    if (leadFacility) leadFacility.value = facilityType;
    if (leadAsset) leadAsset.value = asset;
    if (leadSavings) leadSavings.value = `${formatCurrency(lowSavings)} – ${formatCurrency(highSavings)}`;
  }

  document.getElementById('roi-form')?.addEventListener('submit', (e) => {
    e.preventDefault();
    calculate();

    document.getElementById('results-panel')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });
</script>

</BaseLayout>
